{% doc %}
  Primavera Flowers — 9-tile Instagram-style grid for homepage social proof.
  3x3 grid on desktop, 2-col on tablet, 2-col scroll on mobile.
  Each tile is an image link block — fill via theme editor.
{% enddoc %}

<section
  class="ig-grid section spacing-style color-{{ section.settings.color_scheme }}"
  style="
    {%- render 'spacing-style', settings: section.settings -%};
    background: var(--color-background);
  "
>
  {% if section.settings.heading != blank %}
    <header class="ig-grid__header">
      {% if section.settings.kicker != blank %}
        <p class="ig-grid__kicker">{{ section.settings.kicker | escape }}</p>
      {% endif %}
      <h2 class="ig-grid__heading">{{ section.settings.heading | escape }}</h2>
      {% if section.settings.handle != blank %}
        <a class="ig-grid__handle" href="https://instagram.com/{{ section.settings.handle | replace: '@', '' | escape }}" target="_blank" rel="noopener">
          @{{ section.settings.handle | replace: '@', '' | escape }} →
        </a>
      {% endif %}
    </header>
  {% endif %}

  <ul class="ig-grid__tiles" role="list">
    {%- for block in section.blocks limit: 9 -%}
      <li class="ig-grid__tile" {{ block.shopify_attributes }}>
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}" target="_blank" rel="noopener" aria-label="{{ block.settings.alt | default: 'Instagram post' | escape }}">
        {%- endif -%}
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.alt | default: 'Primavera Flowers Instagram' }}
          {%- else -%}
            <span class="ig-grid__placeholder">
              {{ forloop.index }}
            </span>
          {%- endif -%}
        {%- if block.settings.link != blank -%}
          </a>
        {%- endif -%}
      </li>
    {%- endfor -%}
  </ul>
</section>

{% stylesheet %}
  .ig-grid { padding-block: 64px; }
  .ig-grid__header { text-align: center; margin-bottom: 32px; }
  .ig-grid__kicker {
    font-family: var(--font-accent--family);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.85rem;
    margin-bottom: 8px;
    opacity: 0.7;
  }
  .ig-grid__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin: 0 0 12px;
  }
  .ig-grid__handle {
    color: inherit;
    text-decoration: none;
    font-size: 0.95rem;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
  }
  .ig-grid__tiles {
    list-style: none;
    padding: 0;
    margin: 0 auto;
    max-width: 1200px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
  }
  .ig-grid__tile {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--color-border, #E5DED1);
  }
  .ig-grid__tile a, .ig-grid__tile img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease;
  }
  .ig-grid__tile:hover img { transform: scale(1.04); }
  .ig-grid__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    font-family: var(--font-heading--family);
    font-size: 3rem;
    color: rgba(0,0,0,0.15);
  }
  @media (max-width: 768px) {
    .ig-grid__tiles { grid-template-columns: repeat(2, 1fr); }
    .ig-grid__tile:nth-child(n+9) { display: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Instagram grid",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker (small uppercase line)", "default": "Follow along" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "From our shop" },
    { "type": "text", "id": "handle", "label": "Instagram handle (without @)", "default": "primaveraflowersnyc" },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding-block-start", "label": "Top padding", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding-block-end", "label": "Bottom padding", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 64 }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image (square recommended)" },
        { "type": "url", "id": "link", "label": "Link to Instagram post" },
        { "type": "text", "id": "alt", "label": "Alt text (accessibility)" }
      ]
    }
  ],
  "max_blocks": 9,
  "presets": [
    {
      "name": "Instagram grid (3x3)",
      "blocks": [
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" }
      ]
    }
  ]
}
{% endschema %}
