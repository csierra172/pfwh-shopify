{% comment %}
  Primavera Flowers — homepage v2.
  Simpler copy, cleaner typography (Inter + DM Serif Display only), real shop data,
  Google Reviews block, sage-green brand palette aligned with logo.
  Image assets in /assets:
    primavera-logo.svg, hero-roses.png, madres.png, sympathy.png, florist.png, storefront.png
{% endcomment %}

<style>
  .pl {
    --sage:        #a8b59a;
    --sage-deep:   #7a8a6f;
    --sage-soft:   #c8d2bc;
    --cream:       #f5efe2;
    --cream-2:     #ece4d2;
    --paper:       #faf6ec;
    --ink:         #2a2620;
    --ink-2:       #5a544c;
    --ink-3:       #8a847c;
    --rose:        #d39283;
    --rose-deep:   #b8705d;
    --line:        #e2dac7;
    --pl-serif:    "DM Serif Display", "Times New Roman", serif;
    --pl-sans:     "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--cream); color: var(--ink); font-family: var(--pl-sans);
    font-size: 17px; line-height: 1.55; -webkit-font-smoothing: antialiased;
  }
  .pl * { box-sizing: border-box; margin: 0; padding: 0; }
  .pl img { display: block; max-width: 100%; }
  .pl a { color: inherit; text-decoration: none; }

  /* ───── Announcement ───── */
  .pl-announce { background: var(--sage-deep); color: var(--cream); font-size: 13px; padding: 10px 24px; text-align: center; letter-spacing: 0.01em; font-weight: 500; }
  .pl-announce a { text-decoration: underline; text-underline-offset: 3px; }

  /* ───── Hero ───── */
  .pl-hero { display: grid; grid-template-columns: 1fr 1fr; min-height: 640px; }
  .pl-hero-text { padding: 72px 56px; display: flex; flex-direction: column; justify-content: center; background: var(--cream); }
  .pl-eyebrow { font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--sage-deep); font-weight: 600; margin-bottom: 20px; }
  .pl-hero h1 { font-family: var(--pl-serif); font-weight: 400; font-size: clamp(44px, 5vw, 72px); line-height: 1.05; color: var(--ink); margin-bottom: 24px; max-width: 540px; }
  .pl-hero h1 em { font-style: italic; color: var(--sage-deep); font-weight: 400; }
  .pl-hero p.pl-lede { font-size: 19px; line-height: 1.55; color: var(--ink-2); max-width: 480px; margin-bottom: 32px; }
  .pl-hero-ctas { display: flex; gap: 14px; align-items: center; margin-bottom: 40px; flex-wrap: wrap; }
  .pl-btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 26px; border-radius: 6px; font-size: 15px; font-weight: 600; transition: all .15s; border: none; cursor: pointer; }
  .pl-btn-primary { background: var(--sage-deep); color: var(--cream); }
  .pl-btn-primary:hover { background: var(--ink); }
  .pl-btn-ghost { color: var(--sage-deep); border: 1.5px solid var(--sage-deep); padding: 12px 24px; }
  .pl-btn-ghost:hover { background: var(--sage); color: var(--cream); border-color: var(--sage); }

  .pl-hero-meta { display: grid; grid-template-columns: repeat(3, 1fr); border-top: 1px solid var(--line); padding-top: 24px; gap: 24px; }
  .pl-hero-meta .pl-label { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-3); font-weight: 600; margin-bottom: 6px; }
  .pl-hero-meta .pl-val { font-family: var(--pl-serif); font-size: 22px; color: var(--ink); line-height: 1.1; }
  .pl-hero-meta .pl-val small { font-family: var(--pl-sans); font-size: 12px; display: block; color: var(--ink-3); margin-top: 4px; font-weight: 500; }

  .pl-hero-image { position: relative; overflow: hidden; background: var(--cream-2); }
  .pl-hero-image img { width: 100%; height: 100%; object-fit: cover; }
  .pl-hero-tag { position: absolute; bottom: 24px; left: 24px; background: var(--cream); padding: 14px 18px; max-width: 240px; border-radius: 6px; box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
  .pl-hero-tag .pl-label { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--sage-deep); font-weight: 600; }
  .pl-hero-tag .pl-name { font-family: var(--pl-serif); font-size: 20px; color: var(--ink); margin-top: 4px; line-height: 1.2; }
  .pl-hero-tag .pl-price { font-size: 13px; color: var(--ink-3); margin-top: 4px; }

  /* ───── Promise ───── */
  .pl-promise { background: var(--sage-deep); color: var(--cream); padding: 56px 40px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 40px; }
  .pl-promise .pl-num { font-size: 12px; letter-spacing: 0.14em; color: var(--sage-soft); font-weight: 600; }
  .pl-promise .pl-title { font-family: var(--pl-serif); font-size: 22px; line-height: 1.2; margin: 10px 0 8px; }
  .pl-promise .pl-desc { font-size: 14px; line-height: 1.55; color: rgba(245, 239, 226, 0.85); }

  /* ───── Section ───── */
  .pl-section { padding: 80px 40px; }
  .pl-sec-head { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: end; margin-bottom: 48px; }
  .pl-sec-head h2 { font-family: var(--pl-serif); font-weight: 400; font-size: clamp(36px, 4vw, 56px); line-height: 1.1; color: var(--ink); }
  .pl-sec-head h2 em { font-style: italic; color: var(--sage-deep); }
  .pl-sec-head .pl-right { font-size: 16px; line-height: 1.6; color: var(--ink-2); max-width: 460px; }

  /* ───── Madres ───── */
  .pl-madres { background: var(--paper); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .pl-madres-grid { display: grid; grid-template-columns: 1fr 1fr; align-items: stretch; }
  .pl-madres-text { padding: 72px 48px; display: flex; flex-direction: column; justify-content: center; }
  .pl-madres-text .pl-ribbon { font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--rose-deep); font-weight: 600; margin-bottom: 20px; }
  .pl-madres-text h2 { font-family: var(--pl-serif); font-weight: 400; font-size: clamp(40px, 4.5vw, 64px); line-height: 1.05; color: var(--ink); }
  .pl-madres-text h2 em { font-style: italic; color: var(--sage-deep); }
  .pl-madres-text .pl-es { font-size: 18px; color: var(--ink-2); margin-top: 18px; max-width: 460px; }
  .pl-madres-text .pl-en { font-size: 16px; line-height: 1.6; color: var(--ink-2); max-width: 460px; margin-top: 14px; }
  .pl-madres-text .pl-countdown { margin-top: 32px; display: flex; gap: 10px; padding-top: 24px; border-top: 1px solid var(--line); flex-wrap: wrap; }
  .pl-cd-box { background: var(--cream); padding: 14px 18px; border-radius: 6px; text-align: center; min-width: 76px; border: 1px solid var(--line); }
  .pl-cd-num { font-family: var(--pl-serif); font-size: 30px; color: var(--ink); line-height: 1; }
  .pl-cd-label { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-3); margin-top: 4px; font-weight: 600; }
  .pl-madres-text .pl-ctas { margin-top: 28px; display: flex; gap: 14px; flex-wrap: wrap; }
  .pl-madres-image { position: relative; min-height: 600px; overflow: hidden; }
  .pl-madres-image img { width: 100%; height: 100%; object-fit: cover; }

  /* ───── Occasions ───── */
  .pl-occasions { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1px; background: var(--line); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .pl-occasion { background: var(--cream); padding: 48px 24px 32px; transition: background .25s; cursor: pointer; display: flex; flex-direction: column; gap: 28px; min-height: 280px; }
  .pl-occasion:hover { background: var(--paper); }
  .pl-occasion .pl-num { font-size: 11px; letter-spacing: 0.14em; color: var(--ink-3); font-weight: 600; }
  .pl-occasion .pl-name { font-family: var(--pl-serif); font-size: 28px; line-height: 1.1; color: var(--ink); }
  .pl-occasion .pl-name em { font-style: italic; color: var(--sage-deep); }
  .pl-occasion .pl-copy { font-size: 14px; color: var(--ink-2); margin-top: -16px; line-height: 1.5; }
  .pl-occasion .pl-arrow-link { margin-top: auto; font-size: 13px; color: var(--sage-deep); font-weight: 600; }
  .pl-occasion:hover .pl-arrow-link { color: var(--rose-deep); }

  /* ───── Products ───── */
  .pl-products { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; }
  .pl-product { display: flex; flex-direction: column; gap: 14px; }
  .pl-product .pl-img-wrap { aspect-ratio: 4/5; background: var(--cream-2); overflow: hidden; position: relative; border-radius: 6px; }
  .pl-product .pl-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s; }
  .pl-product:hover .pl-img-wrap img { transform: scale(1.04); }
  .pl-product .pl-badge { position: absolute; top: 12px; left: 12px; background: var(--cream); padding: 5px 10px; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink); font-weight: 600; border-radius: 4px; }
  .pl-product .pl-badge.pl-rose { background: var(--rose-deep); color: var(--cream); }
  .pl-product .pl-row { display: flex; justify-content: space-between; align-items: baseline; }
  .pl-product .pl-name { font-family: var(--pl-serif); font-size: 21px; color: var(--ink); line-height: 1.15; }
  .pl-product .pl-price { font-size: 14px; color: var(--ink-2); font-weight: 600; }
  .pl-product .pl-desc { font-size: 14px; color: var(--ink-3); line-height: 1.5; }

  /* ───── Photo confirmation ───── */
  .pl-promise-photo { display: grid; grid-template-columns: 1fr 1fr; background: var(--cream-2); border-top: 1px solid var(--line); }
  .pl-img-side { position: relative; min-height: 540px; overflow: hidden; }
  .pl-img-side img { width: 100%; height: 100%; object-fit: cover; }
  .pl-text-side { padding: 72px 48px; display: flex; flex-direction: column; justify-content: center; background: var(--cream); }
  .pl-text-side h2 { font-family: var(--pl-serif); font-weight: 400; font-size: clamp(36px, 4vw, 52px); line-height: 1.1; color: var(--ink); margin-top: 16px; }
  .pl-text-side h2 em { font-style: italic; color: var(--sage-deep); }
  .pl-text-side p { font-size: 16px; line-height: 1.6; color: var(--ink-2); max-width: 480px; margin-top: 20px; }
  .pl-stat-row { display: flex; gap: 40px; margin-top: 36px; padding-top: 24px; border-top: 1px solid var(--line); flex-wrap: wrap; }
  .pl-stat .pl-n { font-family: var(--pl-serif); font-size: 36px; color: var(--ink); line-height: 1; }
  .pl-stat .pl-l { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-3); margin-top: 6px; font-weight: 600; }

  /* ───── Reviews ───── */
  .pl-reviews { background: var(--cream); border-top: 1px solid var(--line); padding: 80px 40px; }
  .pl-reviews-head { display: flex; justify-content: space-between; align-items: end; margin-bottom: 40px; gap: 32px; flex-wrap: wrap; }
  .pl-reviews-head h2 { font-family: var(--pl-serif); font-weight: 400; font-size: clamp(36px, 4vw, 52px); line-height: 1.1; color: var(--ink); }
  .pl-reviews-head h2 em { font-style: italic; color: var(--sage-deep); }
  .pl-reviews-rating { display: flex; align-items: center; gap: 12px; }
  .pl-reviews-rating .pl-stars { font-size: 18px; color: #f5b454; letter-spacing: 1px; }
  .pl-reviews-rating .pl-rating-text { font-size: 14px; color: var(--ink-2); font-weight: 600; }
  .pl-reviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .pl-review { background: var(--paper); padding: 28px 26px; border-radius: 8px; border: 1px solid var(--line); display: flex; flex-direction: column; gap: 14px; }
  .pl-review-stars { font-size: 14px; color: #f5b454; letter-spacing: 1px; }
  .pl-review-text { font-size: 15px; color: var(--ink); line-height: 1.55; }
  .pl-review-author { display: flex; align-items: center; gap: 10px; margin-top: auto; padding-top: 12px; border-top: 1px solid var(--line); }
  .pl-review-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--sage); color: var(--cream); display: grid; place-content: center; font-weight: 600; font-size: 13px; }
  .pl-review-name { font-size: 13px; color: var(--ink-2); font-weight: 600; }
  .pl-review-date { font-size: 12px; color: var(--ink-3); }
  .pl-reviews-cta { text-align: center; margin-top: 40px; }
  .pl-reviews-cta a { color: var(--sage-deep); font-weight: 600; font-size: 14px; border-bottom: 1.5px solid var(--sage-deep); padding-bottom: 2px; }
  .pl-reviews-cta a:hover { color: var(--rose-deep); border-color: var(--rose-deep); }

  /* ───── Coverage ───── */
  .pl-coverage { background: var(--ink); color: var(--cream); padding: 80px 40px; }
  .pl-coverage-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 56px; align-items: center; }
  .pl-coverage h2 { font-family: var(--pl-serif); font-weight: 400; font-size: clamp(36px, 4.5vw, 60px); line-height: 1.05; }
  .pl-coverage h2 em { font-style: italic; color: var(--sage-soft); }
  .pl-coverage p { color: rgba(245, 239, 226, 0.78); margin-top: 20px; max-width: 500px; font-size: 16px; line-height: 1.6; }
  .pl-zips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 24px; }
  .pl-zips span { border: 1px solid rgba(245, 239, 226, 0.25); padding: 6px 12px; border-radius: 999px; font-size: 13px; font-weight: 500; }
  .pl-zips span.pl-active { background: var(--sage-deep); border-color: var(--sage-deep); color: var(--cream); }
  .pl-map { background: #1f1d18; aspect-ratio: 1.05/1; position: relative; overflow: hidden; border: 1px solid rgba(245, 239, 226, 0.15); border-radius: 6px; }
  .pl-map svg { width: 100%; height: 100%; }
  .pl-pin { position: absolute; width: 12px; height: 12px; background: var(--rose); border-radius: 50%; box-shadow: 0 0 0 4px rgba(211, 146, 131, 0.25); transform: translate(-50%, -50%); }
  .pl-pin.pl-shop { background: var(--cream); width: 16px; height: 16px; box-shadow: 0 0 0 6px rgba(245, 239, 226, 0.18); }
  .pl-pin.pl-shop::after { content: "PRIMAVERA"; position: absolute; left: 24px; top: 0; font-size: 10px; letter-spacing: 0.14em; color: var(--cream); white-space: nowrap; font-weight: 600; }

  /* ───── Subscriptions teaser (full content lives at /pages/subscriptions) ───── */
  .pl-subs-teaser { background: var(--paper); }
  .pl-subs-teaser-card { max-width: 820px; margin: 0 auto; background: var(--cream); border: 1px solid var(--line); border-radius: 8px; padding: 56px 48px; text-align: center; }
  .pl-subs-teaser-card h2 { font-family: var(--pl-serif); font-weight: 400; font-size: clamp(32px, 4vw, 48px); line-height: 1.1; color: var(--ink); margin: 12px 0 18px; }
  .pl-subs-teaser-card h2 em { font-style: italic; color: var(--sage-deep); }
  .pl-subs-teaser-card p { font-size: 16px; line-height: 1.6; color: var(--ink-2); max-width: 560px; margin: 0 auto 28px; }
  .pl-subs-teaser-ctas { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

  /* ───── Editorial ───── */
  .pl-editorial { display: grid; grid-template-columns: 1fr 1fr; background: var(--cream); }
  .pl-editorial-img { min-height: 600px; overflow: hidden; }
  .pl-editorial-img img { width: 100%; height: 100%; object-fit: cover; }
  .pl-editorial-text { padding: 80px 56px; display: flex; flex-direction: column; justify-content: center; }
  .pl-editorial-text .pl-kicker { font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--sage-deep); font-weight: 600; margin-bottom: 18px; }
  .pl-editorial-text h2 { font-family: var(--pl-serif); font-weight: 400; font-size: clamp(32px, 3.5vw, 44px); line-height: 1.2; color: var(--ink); max-width: 540px; }
  .pl-editorial-text .pl-body { margin-top: 28px; max-width: 480px; font-size: 16px; line-height: 1.7; color: var(--ink-2); }
  .pl-editorial-text .pl-body p + p { margin-top: 14px; }
  .pl-editorial-text .pl-signature { font-family: var(--pl-serif); font-size: 22px; color: var(--ink); margin-top: 32px; }
  .pl-editorial-text .pl-signature small { font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-3); display: block; margin-top: 4px; font-weight: 600; }

  /* ───── Logo block (shown on light-cream surfaces) ───── */
  .pl-logo-mark { width: 88px; height: 88px; border-radius: 50%; background: var(--sage); display: grid; place-content: center; padding: 14px; box-shadow: 0 4px 16px rgba(0,0,0,0.05); }
  .pl-logo-mark svg { width: 100%; height: 100%; }
  .pl-logo-block { display: flex; align-items: center; gap: 18px; margin-bottom: 24px; }
  .pl-logo-block .pl-wordmark { font-family: var(--pl-serif); font-size: 22px; color: var(--ink); letter-spacing: 0.04em; }
  .pl-logo-block .pl-wordmark small { display: block; font-family: var(--pl-sans); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-3); margin-top: 2px; font-weight: 600; }

  @media (max-width: 960px) {
    .pl-hero { grid-template-columns: 1fr; }
    .pl-hero-text { padding: 48px 24px; }
    .pl-hero-image { min-height: 400px; }
    .pl-promise { grid-template-columns: 1fr 1fr; gap: 28px; padding: 40px 24px; }
    .pl-section, .pl-reviews { padding: 56px 24px; }
    .pl-sec-head { grid-template-columns: 1fr; gap: 16px; }
    .pl-madres-grid { grid-template-columns: 1fr; }
    .pl-madres-text { padding: 48px 24px; }
    .pl-madres-image { min-height: 420px; }
    .pl-occasions { grid-template-columns: 1fr 1fr; }
    .pl-products { grid-template-columns: 1fr 1fr; gap: 18px; }
    .pl-promise-photo { grid-template-columns: 1fr; }
    .pl-text-side { padding: 48px 24px; }
    .pl-coverage { padding: 56px 24px; }
    .pl-coverage-grid { grid-template-columns: 1fr; gap: 32px; }
    .pl-reviews-grid { grid-template-columns: 1fr; }
    .pl-subs-teaser-card { padding: 40px 24px; }
    .pl-editorial { grid-template-columns: 1fr; }
    .pl-editorial-text { padding: 48px 24px; }
  }
</style>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<div class="pl">

  <div class="pl-announce">
    Mother's Day is Sunday — hand-delivered across Washington Heights. Order by 2 PM Saturday. <a href="/products/dia-de-las-madres-special">Shop now</a>
  </div>

  <section class="pl-hero">
    <div class="pl-hero-text">
      <div class="pl-logo-block">
        <div class="pl-logo-mark"><img src="{{ 'primavera-logo.svg' | asset_url }}" alt="Primavera Flowers logo"></div>
        <div class="pl-wordmark">Primavera Flowers<small>Washington Heights · Since 2004</small></div>
      </div>
      <span class="pl-eyebrow">★ 4.9 on Google · 200+ reviews · Hablamos español</span>
      <h1>Your <em>real, local</em> Washington Heights florist.</h1>
      <p class="pl-lede">Hand-tied on Fort Washington Avenue since 2004. Hand-delivered across Washington Heights, Hudson Heights, and Inwood the same afternoon. Never a 1-800 wire service. Order by 2 PM — we'll text you a photo before it leaves the shop.</p>
      <div class="pl-hero-ctas">
        <a class="pl-btn pl-btn-primary" href="/collections/all">Send flowers today →</a>
        <a class="pl-btn pl-btn-ghost" href="/products/dia-de-las-madres-special">For Mami, this Sunday</a>
      </div>
      <div class="pl-hero-meta">
        <div>
          <div class="pl-label">Same-day cutoff</div>
          <div class="pl-val">2:00 PM<small>Mon to Sat</small></div>
        </div>
        <div>
          <div class="pl-label">Delivery zone</div>
          <div class="pl-val">10033<small>10032 / 10034 / 10040</small></div>
        </div>
        <div>
          <div class="pl-label">Bouquets from</div>
          <div class="pl-val">$59<small>Hand-tied seasonal</small></div>
        </div>
      </div>
    </div>
    <div class="pl-hero-image">
      <img src="{{ 'hero-roses.png' | asset_url }}" alt="Pink garden roses bouquet hand-tied at Primavera Flowers">
      <div class="pl-hero-tag">
        <div class="pl-label">This week</div>
        <div class="pl-name">Pink Garden Roses</div>
        <div class="pl-price">From $69 · same-day delivery</div>
      </div>
    </div>
  </section>

  <section class="pl-promise">
    <div>
      <div class="pl-num">01</div>
      <div class="pl-title">Real florist. Real shop. Real hands.</div>
      <div class="pl-desc">Not a wire service routing your order three states away. Every bouquet is built at the bench at 463 Fort Washington Ave.</div>
    </div>
    <div>
      <div class="pl-num">02</div>
      <div class="pl-title">A photo before it leaves the shop.</div>
      <div class="pl-desc">We text a quick photo of your actual bouquet — not a stock image — before it heads out the door. If it's not right, we remake it.</div>
    </div>
    <div>
      <div class="pl-num">03</div>
      <div class="pl-title">Cut this morning. Built today.</div>
      <div class="pl-desc">Our buyer is on the A train to the 28th Street market before sunrise. Stems land at the shop by 9, in your hands by 5.</div>
    </div>
    <div>
      <div class="pl-num">04</div>
      <div class="pl-title">Family-owned. Two decades. One block.</div>
      <div class="pl-desc">Bilingual, family-run on the corner of 187th since 2004. Walk in, call, or order online — by your second order we'll know your name.</div>
    </div>
  </section>

  <section class="pl-madres" id="pl-madres">
