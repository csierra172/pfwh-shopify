{% comment %}
  Primavera Flowers — editorial landing page section.
  Self-contained: own CSS, HTML, JS. Renders the full homepage.
  Image assets must live in /assets:
    hero-roses.png, madres.png, sympathy.png, florist.png, storefront.png
  Configurable copy via section settings (see schema at bottom).
{% endcomment %}

<style>
  .primavera-landing {
    --green: #1e3a2c;
    --green-2: #2c4a3a;
    --green-deep: #142319;
    --ivory: #f5efe2;
    --ivory-2: #ece4d2;
    --paper: #faf6ec;
    --ink: #221b14;
    --ink-2: #4a4036;
    --rose: #d39283;
    --rose-deep: #b8705d;
    --line: #d8cdb6;
    --pl-serif: "Cormorant Garamond", "Times New Roman", serif;
    --pl-sans: "DM Sans", system-ui, sans-serif;
    --pl-mono: "JetBrains Mono", ui-monospace, monospace;
    background: var(--ivory); color: var(--ink); font-family: var(--pl-sans);
    font-size: 16px; line-height: 1.5; -webkit-font-smoothing: antialiased;
  }
  .primavera-landing * { box-sizing: border-box; margin: 0; padding: 0; }
  .primavera-landing img { display: block; max-width: 100%; }
  .primavera-landing a { color: inherit; text-decoration: none; }

  /* Announcement ticker */
  .pl-announce { background: var(--green-deep); color: var(--ivory); font-family: var(--pl-mono); font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; overflow: hidden; white-space: nowrap; }
  .pl-announce-track { display: inline-flex; gap: 3rem; padding: 12px 0; animation: pl-slide 48s linear infinite; }
  .pl-announce-track span { display: inline-flex; align-items: center; gap: 0.75rem; }
  .pl-announce-track .pl-dot { width: 4px; height: 4px; background: var(--rose); border-radius: 50%; }
  @keyframes pl-slide { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  /* Hero */
  .pl-hero { display: grid; grid-template-columns: 1fr 1fr; min-height: 720px; border-bottom: 1px solid var(--line); }
  .pl-hero-text { padding: 80px 64px 64px; display: flex; flex-direction: column; justify-content: space-between; background: var(--ivory); position: relative; }
  .pl-eyebrow { font-family: var(--pl-mono); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--rose-deep); display: inline-flex; align-items: center; gap: 12px; }
  .pl-eyebrow::before { content: ""; width: 32px; height: 1px; background: var(--rose-deep); }
  .pl-hero h1 { font-family: var(--pl-serif); font-weight: 400; font-size: clamp(56px, 6.4vw, 96px); line-height: 0.96; letter-spacing: -0.01em; color: var(--green-deep); margin: 28px 0; }
  .pl-hero h1 em { font-style: italic; color: var(--rose-deep); font-weight: 400; }
  .pl-hero p.pl-lede { font-family: var(--pl-serif); font-size: 22px; line-height: 1.4; max-width: 460px; color: var(--ink-2); font-style: italic; margin-bottom: 36px; }
  .pl-hero-ctas { display: flex; gap: 12px; align-items: center; margin-bottom: 48px; flex-wrap: wrap; }
  .pl-btn { display: inline-flex; align-items: center; gap: 10px; padding: 15px 26px; border-radius: 999px; font-size: 14px; font-weight: 500; transition: transform .15s, background .2s; border: none; cursor: pointer; }
  .pl-btn-primary { background: var(--green); color: var(--ivory); }
  .pl-btn-primary:hover { background: var(--green-deep); }
  .pl-btn-ghost { color: var(--green); border-bottom: 1px solid var(--green); border-radius: 0; padding: 8px 2px; }
  .pl-btn-ghost:hover { color: var(--rose-deep); border-color: var(--rose-deep); }
  .pl-arrow { font-size: 16px; }

  .pl-hero-meta { display: grid; grid-template-columns: repeat(3, 1fr); border-top: 1px solid var(--line); padding-top: 28px; }
  .pl-hero-meta .pl-item { padding-right: 20px; }
  .pl-hero-meta .pl-label { font-family: var(--pl-mono); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-2); margin-bottom: 8px; }
  .pl-hero-meta .pl-val { font-family: var(--pl-serif); font-size: 22px; color: var(--green-deep); line-height: 1.1; }
  .pl-hero-meta .pl-val small { font-family: var(--pl-sans); font-size: 12px; display: block; color: var(--ink-2); margin-top: 6px; letter-spacing: 0.04em; }

  .pl-hero-image { position: relative; overflow: hidden; background: var(--ivory-2); }
  .pl-hero-image img { width: 100%; height: 100%; object-fit: cover; }
  .pl-hero-tag { position: absolute; bottom: 28px; left: 28px; background: var(--paper); padding: 14px 18px; max-width: 240px; border-left: 2px solid var(--rose-deep); }
  .pl-hero-tag .pl-label { font-family: var(--pl-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--rose-deep); }
  .pl-hero-tag .pl-name { font-family: var(--pl-serif); font-size: 22px; color: var(--green-deep); margin-top: 6px; line-height: 1.15; }
  .pl-hero-tag .pl-price { font-family: var(--pl-mono); font-size: 12px; color: var(--ink-2); margin-top: 8px; }

  /* Promise band */
  .pl-promise { background: var(--green); color: var(--ivory); padding: 56px 40px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 48px; align-items: start; }
  .pl-promise .pl-num { font-family: var(--pl-mono); font-size: 11px; letter-spacing: 0.16em; color: var(--rose); opacity: 0.85; }
  .pl-promise .pl-title { font-family: var(--pl-serif); font-size: 24px; line-height: 1.2; margin: 12px 0 10px; font-style: italic; }
  .pl-promise .pl-desc { font-size: 14px; line-height: 1.55; opacity: 0.85; }

  /* Section header */
  .pl-section { padding: 96px 40px; }
  .pl-sec-head { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: end; margin-bottom: 56px; }
  .pl-sec-head h2 { font-family: var(--pl-serif); font-weight: 400; font-size: clamp(44px, 5vw, 72px); line-height: 1.0; color: var(--green-deep); letter-spacing: -0.005em; }
  .pl-sec-head h2 em { font-style: italic; color: var(--rose-deep); }
  .pl-sec-head .pl-right { font-size: 16px; line-height: 1.6; color: var(--ink-2); max-width: 460px; justify-self: end; }
  .pl-sec-head .pl-right p + p { margin-top: 12px; }

  /* Día de las Madres */
  .pl-madres { background: var(--paper); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .pl-madres-grid { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 0; align-items: stretch; }
  .pl-madres-text { padding: 80px 56px 80px 40px; display: flex; flex-direction: column; justify-content: center; }
  .pl-madres-text .pl-ribbon { font-family: var(--pl-mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--rose-deep); display: inline-flex; gap: 12px; align-items: center; margin-bottom: 24px; }
  .pl-madres-text h2 { font-family: var(--pl-serif); font-weight: 400; font-size: clamp(56px, 6vw, 88px); line-height: 0.95; color: var(--green-deep); }
  .pl-madres-text h2 em { font-style: italic; color: var(--rose-deep); }
  .pl-madres-text .pl-es { font-family: var(--pl-serif); font-style: italic; font-size: 26px; color: var(--ink-2); margin-top: 24px; max-width: 500px; }
  .pl-madres-text .pl-en { font-size: 16px; line-height: 1.6; color: var(--ink-2); max-width: 480px; margin-top: 16px; }
  .pl-madres-text .pl-countdown { margin-top: 40px; display: flex; gap: 12px; align-items: stretch; border-top: 1px solid var(--line); padding-top: 32px; }
  .pl-countdown .pl-box { background: var(--ivory); padding: 16px 20px; border: 1px solid var(--line); text-align: center; min-width: 84px; }
  .pl-countdown .pl-num { font-family: var(--pl-serif); font-size: 36px; color: var(--green-deep); line-height: 1; }
  .pl-countdown .pl-label { font-family: var(--pl-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-2); margin-top: 6px; }
  .pl-madres-text .pl-ctas { margin-top: 32px; display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
  .pl-madres-image { position: relative; min-height: 720px; overflow: hidden; }
  .pl-madres-image img { width: 100%; height: 100%; object-fit: cover; }
  .pl-madres-image .pl-stamp { position: absolute; top: 40px; right: 40px; width: 140px; height: 140px; border-radius: 50%; background: var(--rose-deep); color: var(--ivory); display: grid; place-content: center; text-align: center; font-family: var(--pl-serif); font-size: 18px; line-height: 1.1; font-style: italic; transform: rotate(-8deg); box-shadow: 0 12px 30px rgba(0,0,0,0.18); }
  .pl-madres-image .pl-stamp small { display: block; font-family: var(--pl-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; font-style: normal; margin-top: 6px; opacity: 0.85; }

  /* Occasions */
  .pl-occasions { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1px; background: var(--line); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .pl-occasion { background: var(--ivory); padding: 56px 28px 40px; transition: background .25s; cursor: pointer; display: flex; flex-direction: column; gap: 36px; min-height: 320px; }
  .pl-occasion:hover { background: var(--paper); }
  .pl-occasion .pl-num { font-family: var(--pl-mono); font-size: 11px; letter-spacing: 0.14em; color: var(--ink-2); }
  .pl-occasion .pl-name { font-family: var(--pl-serif); font-size: 32px; line-height: 1.05; color: var(--green-deep); }
  .pl-occasion .pl-name em { font-style: italic; color: var(--rose-deep); }
  .pl-occasion .pl-copy { font-size: 13px; color: var(--ink-2); margin-top: -24px; line-height: 1.5; }
  .pl-occasion .pl-arrow-link { margin-top: auto; font-family: var(--pl-mono); font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--green); display: inline-flex; align-items: center; gap: 8px; }
  .pl-occasion:hover .pl-arrow-link { color: var(--rose-deep); }

  /* Products */
  .pl-products { display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; }
  .pl-product { display: flex; flex-direction: column; gap: 16px; }
  .pl-product .pl-img-wrap { aspect-ratio: 4/5; background: var(--ivory-2); overflow: hidden; position: relative; }
  .pl-product .pl-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform .6s; }
  .pl-product:hover .pl-img-wrap img { transform: scale(1.04); }
  .pl-product .pl-badge { position: absolute; top: 14px; left: 14px; background: var(--paper); padding: 5px 10px; font-family: var(--pl-mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--green-deep); }
  .pl-product .pl-badge.pl-rose { background: var(--rose-deep); color: var(--ivory); }
  .pl-product .pl-quick { position: absolute; bottom: 0; left: 0; right: 0; background: var(--green); color: var(--ivory); padding: 12px; font-family: var(--pl-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; text-align: center; transform: translateY(100%); transition: transform .25s; }
  .pl-product:hover .pl-quick { transform: translateY(0); }
  .pl-product .pl-row { display: flex; justify-content: space-between; align-items: baseline; }
  .pl-product .pl-name { font-family: var(--pl-serif); font-size: 22px; color: var(--green-deep); line-height: 1.15; }
  .pl-product .pl-price { font-family: var(--pl-mono); font-size: 13px; color: var(--ink); }
  .pl-product .pl-desc { font-size: 13px; color: var(--ink-2); line-height: 1.5; }

  /* Photo confirmation */
  .pl-promise-photo { display: grid; grid-template-columns: 1fr 1fr; background: var(--ivory-2); border-top: 1px solid var(--line); }
  .pl-promise-photo .pl-img-side { background: var(--ivory-2); position: relative; min-height: 600px; overflow: hidden; }
  .pl-promise-photo .pl-img-side img { width: 100%; height: 100%; object-fit: cover; }
  .pl-promise-photo .pl-receipt { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) rotate(-4deg); background: var(--paper); padding: 24px 28px; width: 320px; box-shadow: 0 24px 60px rgba(20, 35, 25, 0.28); border: 1px solid var(--line); }
  .pl-receipt .pl-head { font-family: var(--pl-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-2); display: flex; justify-content: space-between; border-bottom: 1px dashed var(--line); padding-bottom: 10px; margin-bottom: 14px; }
  .pl-receipt .pl-ph { aspect-ratio: 1/1; background: linear-gradient(135deg, #e3c8c0, #c9a89a); display: grid; place-content: center; color: var(--ivory); font-family: var(--pl-serif); font-style: italic; font-size: 14px; margin-bottom: 14px; position: relative; overflow: hidden; }
  .pl-receipt .pl-ph img { width: 100%; height: 100%; object-fit: cover; }
  .pl-receipt .pl-line { font-family: var(--pl-serif); font-style: italic; font-size: 18px; color: var(--green-deep); line-height: 1.3; }
  .pl-receipt .pl-meta { font-family: var(--pl-mono); font-size: 10px; letter-spacing: 0.1em; color: var(--ink-2); margin-top: 12px; }
  .pl-promise-photo .pl-text-side { padding: 80px 56px; display: flex; flex-direction: column; justify-content: center; background: var(--ivory); }
  .pl-promise-photo h2 { font-family: var(--pl-serif); font-weight: 400; font-size: clamp(40px, 4.6vw, 64px); line-height: 1.0; color: var(--green-deep); }
  .pl-promise-photo h2 em { font-style: italic; color: var(--rose-deep); }
  .pl-promise-photo p { font-size: 17px; line-height: 1.6; color: var(--ink-2); max-width: 480px; margin-top: 28px; }
  .pl-promise-photo .pl-stat-row { display: flex; gap: 56px; margin-top: 48px; border-top: 1px solid var(--line); padding-top: 28px; flex-wrap: wrap; }
  .pl-stat .pl-n { font-family: var(--pl-serif); font-size: 40px; color: var(--green-deep); line-height: 1; }
  .pl-stat .pl-l { font-family: var(--pl-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-2); margin-top: 8px; }

  /* Coverage */
  .pl-coverage { background: var(--green-deep); color: var(--ivory); padding: 96px 40px; }
  .pl-coverage-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 64px; align-items: center; }
  .pl-coverage h2 { font-family: var(--pl-serif); font-weight: 400; font-size: clamp(44px, 5vw, 76px); line-height: 0.98; }
  .pl-coverage h2 em { font-style: italic; color: var(--rose); }
  .pl-coverage p { color: rgba(245, 239, 226, 0.78); margin-top: 24px; max-width: 520px; font-size: 16px; line-height: 1.6; }
  .pl-zips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 28px; }
  .pl-zips span { border: 1px solid rgba(245, 239, 226, 0.25); padding: 6px 12px; border-radius: 999px; font-family: var(--pl-mono); font-size: 12px; letter-spacing: 0.06em; }
  .pl-zips span.pl-active { background: var(--rose-deep); border-color: var(--rose-deep); }
  .pl-map { background: var(--green-2); aspect-ratio: 1.05/1; position: relative; overflow: hidden; border: 1px solid rgba(245, 239, 226, 0.15); }
  .pl-map svg { width: 100%; height: 100%; }
  .pl-pin { position: absolute; width: 14px; height: 14px; background: var(--rose); border-radius: 50%; box-shadow: 0 0 0 4px rgba(211, 146, 131, 0.25); transform: translate(-50%, -50%); }
  .pl-pin.pl-shop { background: var(--ivory); width: 18px; height: 18px; box-shadow: 0 0 0 6px rgba(245, 239, 226, 0.18); }
  .pl-pin.pl-shop::after { content: "PRIMAVERA"; position: absolute; left: 28px; top: 0; font-family: var(--pl-mono); font-size: 10px; letter-spacing: 0.14em; color: var(--ivory); white-space: nowrap; }
  .pl-map-label { position: absolute; font-family: var(--pl-mono); font-size: 10px; letter-spacing: 0.1em; color: rgba(245, 239, 226, 0.55); text-transform: uppercase; }

  /* Subscriptions */
  .pl-subs { background: var(--paper); }
  .pl-sub-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .pl-sub { background: var(--ivory); padding: 40px 32px; border: 1px solid var(--line); display: flex; flex-direction: column; min-height: 380px; position: relative; }
  .pl-sub.pl-featured { background: var(--green); color: var(--ivory); border-color: var(--green); }
  .pl-sub.pl-featured .pl-sub-name, .pl-sub.pl-featured .pl-sub-price { color: var(--ivory); }
  .pl-sub.pl-featured .pl-sub-meta, .pl-sub.pl-featured .pl-sub-feat li { color: rgba(245, 239, 226, 0.78); }
  .pl-sub.pl-featured .pl-sub-feat li::before { background: var(--rose); }
  .pl-sub-tag { font-family: var(--pl-mono); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--rose-deep); margin-bottom: 28px; }
  .pl-sub.pl-featured .pl-sub-tag { color: var(--rose); }
  .pl-sub-name { font-family: var(--pl-serif); font-size: 36px; color: var(--green-deep); line-height: 1; }
  .pl-sub-name em { font-style: italic; }
  .pl-sub-price { font-family: var(--pl-serif); font-size: 28px; color: var(--green-deep); margin-top: 14px; }
  .pl-sub-price small { font-family: var(--pl-sans); font-size: 13px; color: var(--ink-2); margin-left: 6px; }
  .pl-sub.pl-featured .pl-sub-price small { color: rgba(245, 239, 226, 0.7); }
  .pl-sub-meta { font-size: 13px; color: var(--ink-2); margin-top: 8px; }
  .pl-sub-feat { list-style: none; margin: 28px 0; padding: 0; display: flex; flex-direction: column; gap: 10px; }
  .pl-sub-feat li { font-size: 14px; color: var(--ink-2); padding-left: 18px; position: relative; }
  .pl-sub-feat li::before { content: ""; position: absolute; left: 0; top: 8px; width: 8px; height: 1px; background: var(--rose-deep); }
  .pl-sub .pl-btn { margin-top: auto; align-self: flex-start; }
  .pl-sub.pl-featured .pl-btn-primary { background: var(--ivory); color: var(--green-deep); }
  .pl-sub.pl-featured .pl-btn-primary:hover { background: var(--rose); color: var(--green-deep); }

  /* Editorial */
  .pl-editorial { display: grid; grid-template-columns: 1fr 1fr; gap: 0; background: var(--ivory); }
  .pl-editorial-img { min-height: 720px; overflow: hidden; }
  .pl-editorial-img img { width: 100%; height: 100%; object-fit: cover; }
  .pl-editorial-text { padding: 96px 64px; display: flex; flex-direction: column; justify-content: center; }
  .pl-editorial-text .pl-kicker { font-family: var(--pl-mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--rose-deep); margin-bottom: 24px; }
  .pl-editorial-text h2 { font-family: var(--pl-serif); font-weight: 400; font-style: italic; font-size: clamp(36px, 3.6vw, 52px); line-height: 1.15; color: var(--green-deep); max-width: 540px; }
  .pl-editorial-text h2 .pl-pull { font-style: normal; color: var(--rose-deep); }
  .pl-editorial-text .pl-body { margin-top: 40px; max-width: 480px; columns: 1; font-size: 15px; line-height: 1.7; color: var(--ink-2); }
  .pl-editorial-text .pl-body p + p { margin-top: 12px; }
  .pl-editorial-text .pl-signature { font-family: var(--pl-serif); font-style: italic; font-size: 24px; color: var(--green-deep); margin-top: 40px; }
  .pl-editorial-text .pl-signature small { font-family: var(--pl-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; font-style: normal; color: var(--ink-2); display: block; margin-top: 6px; }

  /* Quote */
  .pl-quote-strip { background: var(--rose-deep); color: var(--ivory); padding: 80px 40px; text-align: center; }
  .pl-quote-strip blockquote { font-family: var(--pl-serif); font-style: italic; font-weight: 400; font-size: clamp(28px, 3vw, 44px); line-height: 1.25; max-width: 920px; margin: 0 auto; }
  .pl-quote-strip .pl-attribution { font-family: var(--pl-mono); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; margin-top: 28px; opacity: 0.85; }

  @media (max-width: 960px) {
    .pl-hero { grid-template-columns: 1fr; }
    .pl-hero-text { padding: 48px 24px; }
    .pl-hero-image { min-height: 420px; }
    .pl-promise { grid-template-columns: 1fr 1fr; gap: 32px; padding: 40px 24px; }
    .pl-section { padding: 64px 24px; }
    .pl-sec-head { grid-template-columns: 1fr; gap: 24px; }
    .pl-madres-grid { grid-template-columns: 1fr; }
    .pl-madres-text { padding: 48px 24px; }
    .pl-madres-image { min-height: 460px; }
    .pl-occasions { grid-template-columns: 1fr 1fr; }
    .pl-products { grid-template-columns: 1fr 1fr; gap: 20px; }
    .pl-promise-photo { grid-template-columns: 1fr; }
    .pl-promise-photo .pl-text-side { padding: 48px 24px; }
    .pl-coverage { padding: 64px 24px; }
    .pl-coverage-grid { grid-template-columns: 1fr; }
    .pl-sub-grid { grid-template-columns: 1fr; }
    .pl-editorial { grid-template-columns: 1fr; }
    .pl-editorial-text { padding: 48px 24px; }
  }
</style>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<div class="primavera-landing">

  <div class="pl-announce">
    <div class="pl-announce-track">
      <span><span class="pl-dot"></span> Día de las Madres · Sunday May 10 · order by 2 PM Saturday for hand-delivery</span>
      <span><span class="pl-dot"></span> Free same-day delivery in 10032 / 10033 / 10034 / 10040 over $85</span>
