<script>
(function() {
  var target = new Date('2026-05-10T09:00:00-04:00').getTime();
  var elD = document.getElementById('pl-cd-d');
  var elH = document.getElementById('pl-cd-h');
  var elM = document.getElementById('pl-cd-m');
  var elS = document.getElementById('pl-cd-s');
  function pad(n) { return String(Math.max(0, n)).padStart(2, '0'); }
  function tick() {
    var now = Date.now();
    var diff = Math.max(0, target - now);
    var days = Math.floor(diff / 86400000); diff -= days * 86400000;
    var hours = Math.floor(diff / 3600000); diff -= hours * 3600000;
    var mins = Math.floor(diff / 60000); diff -= mins * 60000;
    var secs = Math.floor(diff / 1000);
    if (elD) elD.textContent = pad(days);
    if (elH) elH.textContent = pad(hours);
    if (elM) elM.textContent = pad(mins);
    if (elS) elS.textContent = pad(secs);
  }
  tick();
  setInterval(tick, 1000);
})();
</script>

