{% comment %}
  Primavera, Mother's Day banner with countdown.
  Editable: ribbon, headlines (EN + ES), CTAs, image, target date.
{% endcomment %}

<section class="pv-madres pv-section">
  <div class="pv-madres-grid">
    <div class="pv-madres-text">
      {% if section.settings.ribbon != blank %}
        <div class="pv-ribbon">{{ section.settings.ribbon }}</div>
      {% endif %}
      {% if section.settings.headline != blank %}{{ section.settings.headline }}{% endif %}
      {% if section.settings.body_es != blank %}<p class="pv-es">{{ section.settings.body_es }}</p>{% endif %}
      {% if section.settings.body_en != blank %}<p class="pv-en">{{ section.settings.body_en }}</p>{% endif %}
      {% if section.settings.show_countdown %}
        <div class="pv-countdown" id="pv-madres-cd">
          <div class="pv-cd-box"><div class="pv-cd-num" data-d>00</div><div class="pv-cd-label">Days</div></div>
          <div class="pv-cd-box"><div class="pv-cd-num" data-h>00</div><div class="pv-cd-label">Hours</div></div>
          <div class="pv-cd-box"><div class="pv-cd-num" data-m>00</div><div class="pv-cd-label">Min</div></div>
          <div class="pv-cd-box"><div class="pv-cd-num" data-s>00</div><div class="pv-cd-label">Sec</div></div>
        </div>
      {% endif %}
      <div class="pv-ctas">
        {% if section.settings.cta_label != blank %}
          <a class="pv-btn pv-btn-primary" href="{{ section.settings.cta_link | default: '/products/dia-de-las-madres' }}">{{ section.settings.cta_label }}</a>
        {% endif %}
      </div>
    </div>
    <div class="pv-madres-image">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: section.settings.image.alt | default: "Mother's Day bouquet" }}
      {% else %}
        <img src="{{ 'madres.png' | asset_url }}" alt="Mother's Day bouquet for delivery" loading="lazy">
      {% endif %}
    </div>
  </div>
</section>

{% if section.settings.show_countdown and section.settings.target_iso != blank %}
<script>
(function(){
  var root = document.getElementById('pv-madres-cd');
  if (!root) return;
  var target = new Date('{{ section.settings.target_iso }}').getTime();
  var elD = root.querySelector('[data-d]'); var elH = root.querySelector('[data-h]');
  var elM = root.querySelector('[data-m]'); var elS = root.querySelector('[data-s]');
  function pad(n){ return String(Math.max(0,n)).padStart(2,'0'); }
  function tick(){
    var diff = Math.max(0, target - Date.now());
    var d = Math.floor(diff/86400000); diff -= d*86400000;
    var h = Math.floor(diff/3600000); diff -= h*3600000;
    var m = Math.floor(diff/60000); diff -= m*60000;
    var s = Math.floor(diff/1000);
    if(elD) elD.textContent = pad(d);
    if(elH) elH.textContent = pad(h);
    if(elM) elM.textContent = pad(m);
    if(elS) elS.textContent = pad(s);
  }
  tick(); setInterval(tick, 1000);
})();
</script>
{% endif %}

{% stylesheet %}
  .pv-section { --sage:#a8b59a; --sage-deep:#7a8a6f; --cream:#f5efe2; --paper:#faf6ec; --ink:#2a2620; --ink-2:#5a544c; --ink-3:#8a847c; --rose-deep:#b8705d; --line:#e2dac7; --pv-serif:"DM Serif Display","Times New Roman",serif; --pv-sans:"Inter",system-ui,-apple-system,sans-serif; }
  .pv-madres { background: var(--paper); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); font-family: var(--pv-sans); color: var(--ink); }
  .pv-madres-grid { display: grid; grid-template-columns: 1fr 1fr; align-items: stretch; }
  .pv-madres-text { padding: 72px 48px; display: flex; flex-direction: column; justify-content: center; }
  .pv-madres-text .pv-ribbon { font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--rose-deep); font-weight: 600; margin-bottom: 20px; }
  .pv-madres-text h2 { font-family: var(--pv-serif); font-weight: 400; font-size: clamp(36px, 4.5vw, 60px); line-height: 1.05; color: var(--ink); margin: 0; }
  .pv-madres-text h2 em { font-style: italic; color: var(--sage-deep); }
  .pv-madres-text .pv-es { font-size: 18px; color: var(--ink-2); margin-top: 18px; max-width: 460px; line-height: 1.55; }
  .pv-madres-text .pv-en { font-size: 16px; line-height: 1.6; color: var(--ink-2); max-width: 460px; margin-top: 14px; }
  .pv-countdown { margin-top: 32px; display: flex; gap: 10px; padding-top: 24px; border-top: 1px solid var(--line); flex-wrap: wrap; }
  .pv-cd-box { background: var(--cream); padding: 14px 18px; border-radius: 6px; text-align: center; min-width: 76px; border: 1px solid var(--line); }
  .pv-cd-num { font-family: var(--pv-serif); font-size: 30px; color: var(--ink); line-height: 1; }
  .pv-cd-label { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-3); margin-top: 4px; font-weight: 600; }
  .pv-ctas { margin-top: 28px; display: flex; gap: 14px; flex-wrap: wrap; }
  .pv-btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 26px; border-radius: 6px; font-size: 15px; font-weight: 600; transition: all .15s; border: none; cursor: pointer; text-decoration: none; }
  .pv-btn-primary { background: var(--sage-deep); color: var(--cream); }
  .pv-btn-primary:hover { background: var(--ink); }
  .pv-madres-image { position: relative; min-height: 600px; overflow: hidden; }
  .pv-madres-image img { width: 100%; height: 100%; object-fit: cover; display: block; }
  @media (max-width: 960px) {
    .pv-madres-grid { grid-template-columns: 1fr; }
    .pv-madres-text { padding: 48px 24px; }
    .pv-madres-image { min-height: 360px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Primavera Madres",
  "tag": "section",
  "class": "primavera-madres-section",
  "settings": [
    { "type": "text", "id": "ribbon", "label": "Ribbon (uppercase eyebrow)", "default": "Mother's Day · Día de las Madres · Sunday May 10" },
    { "type": "richtext", "id": "headline", "label": "Headline (use h2)", "default": "<h2>Para Mami,<br>con todo nuestro <em>cariño</em>.</h2>" },
    { "type": "textarea", "id": "body_es", "label": "Body in Spanish", "default": "Flores frescas entregadas hoy en todo Washington Heights. Toda la 10032, 10033, 10034 y 10040 antes de las cinco." },
    { "type": "textarea", "id": "body_en", "label": "Body in English", "default": "Hand-tied bouquets built for the day, with a Spanish or English card in your handwriting (or ours). Order before 2 PM Saturday and we'll walk it over to Mami's apartment Sunday morning." },
    { "type": "checkbox", "id": "show_countdown", "label": "Show countdown timer", "default": true },
    { "type": "text", "id": "target_iso", "label": "Countdown target ISO date (e.g. 2027-05-09T09:00:00-04:00)", "default": "2027-05-09T09:00:00-04:00" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop Mother's Day →" },
    { "type": "url", "id": "cta_link", "label": "CTA link" },
    { "type": "image_picker", "id": "image", "label": "Section image (defaults to madres.png)" }
  ],
  "presets": [{ "name": "Primavera Madres" }]
}
{% endschema %}
