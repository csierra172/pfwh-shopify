{% comment %}
  Primavera Mother's Day band. Bilingual headlines + optional countdown +
  CTA. All settings have hardcoded fallbacks. Never renders empty.
{% endcomment %}

<section class="pv-madres pv-section">
  <div class="pv-madres-grid">
    <div class="pv-madres-text">
      <div class="pv-ribbon">{{ section.settings.ribbon | default: "Mother's Day · Día de las Madres · May 10" }}</div>
      {% if section.settings.headline != blank %}{{ section.settings.headline }}{% else %}<h2>Para Mami,<br>con todo nuestro <em>cariño</em>.</h2>{% endif %}
      <p class="pv-es">{{ section.settings.body_es | default: 'Flores frescas entregadas hoy en todo Washington Heights. Toda la 10032, 10033, 10034 y 10040 antes de las cinco.' }}</p>
      <p class="pv-en">{{ section.settings.body_en | default: "Hand-tied bouquets built for the day, with a Spanish or English card in your handwriting (or ours). Order before 2 PM Saturday and we'll walk it over to Mami's apartment Sunday morning." }}</p>
      {% if section.settings.show_countdown %}
        <div class="pv-countdown" id="pv-madres-cd">
          <div class="pv-cd-box"><div class="pv-cd-num" data-d>00</div><div class="pv-cd-label">Days</div></div>
          <div class="pv-cd-box"><div class="pv-cd-num" data-h>00</div><div class="pv-cd-label">Hours</div></div>
          <div class="pv-cd-box"><div class="pv-cd-num" data-m>00</div><div class="pv-cd-label">Min</div></div>
          <div class="pv-cd-box"><div class="pv-cd-num" data-s>00</div><div class="pv-cd-label">Sec</div></div>
        </div>
      {% endif %}
      <div class="pv-ctas">
        <a class="pv-btn pv-btn-primary" href="{{ section.settings.cta_link | default: '/products/dia-de-las-madres' }}">{{ section.settings.cta_label | default: "Shop Mother's Day →" }}</a>
      </div>
    </div>
    <div class="pv-madres-image">
      {% if section.settings.image != blank %}{{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: section.settings.image.alt | default: "Mother's Day bouquet" }}{% else %}<img src="{{ 'madres.png' | asset_url }}" alt="Mother's Day bouquet" loading="lazy">{% endif %}
    </div>
  </div>
</section>

{% if section.settings.show_countdown and section.settings.target_iso != blank %}
<script>
(function(){var r=document.getElementById('pv-madres-cd');if(!r)return;var t=new Date('{{ section.settings.target_iso }}').getTime();if(isNaN(t))return;var eD=r.querySelector('[data-d]'),eH=r.querySelector('[data-h]'),eM=r.querySelector('[data-m]'),eS=r.querySelector('[data-s]');function p(n){return String(Math.max(0,n)).padStart(2,'0');}function tk(){var d=Math.max(0,t-Date.now()),D=Math.floor(d/86400000);d-=D*86400000;var H=Math.floor(d/3600000);d-=H*3600000;var M=Math.floor(d/60000);d-=M*60000;var S=Math.floor(d/1000);if(eD)eD.textContent=p(D);if(eH)eH.textContent=p(H);if(eM)eM.textContent=p(M);if(eS)eS.textContent=p(S);}tk();setInterval(tk,1000);})();
</script>
{% endif %}

{% stylesheet %}
  .pv-section { --sage:#a8b59a; --sage-deep:#7a8a6f; --cream:#f5efe2; --paper:#faf6ec; --ink:#2a2620; --ink-2:#5a544c; --ink-3:#8a847c; --rose-deep:#b8705d; --line:#e2dac7; --pv-serif:"DM Serif Display","Times New Roman",serif; --pv-sans:"Inter",system-ui,-apple-system,sans-serif; }
  .pv-madres { background: var(--paper); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); font-family: var(--pv-sans); color: var(--ink); }
  .pv-madres-grid { display: grid; grid-template-columns: 1fr 1fr; align-items: stretch; }
  .pv-madres-text { padding: 72px 48px; display: flex; flex-direction: column; justify-content: center; }
  .pv-ribbon { font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--rose-deep); font-weight: 600; margin-bottom: 20px; }
  .pv-madres-text h2 { font-family: var(--pv-serif); font-weight: 400; font-size: clamp(36px,4.5vw,60px); line-height: 1.05; color: var(--ink); margin: 0; }
  .pv-madres-text h2 em { font-style: italic; color: var(--sage-deep); }
  .pv-es { font-size: 18px; color: var(--ink-2); margin-top: 18px; max-width: 460px; line-height: 1.55; }
  .pv-en { font-size: 16px; line-height: 1.6; color: var(--ink-2); max-width: 460px; margin-top: 14px; }
  .pv-countdown { margin-top: 32px; display: flex; gap: 10px; padding-top: 24px; border-top: 1px solid var(--line); flex-wrap: wrap; }
  .pv-cd-box { background: var(--cream); padding: 14px 18px; border-radius: 6px; text-align: center; min-width: 76px; border: 1px solid var(--line); }
  .pv-cd-num { font-family: var(--pv-serif); font-size: 30px; color: var(--ink); line-height: 1; }
  .pv-cd-label { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-3); margin-top: 4px; font-weight: 600; }
  .pv-ctas { margin-top: 28px; display: flex; gap: 14px; flex-wrap: wrap; }
  .pv-btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 26px; border-radius: 6px; font-size: 15px; font-weight: 600; text-decoration: none; transition: all .15s; }
  .pv-btn-primary { background: var(--sage-deep); color: var(--cream); }
  .pv-btn-primary:hover { background: var(--ink); }
  .pv-madres-image { position: relative; min-height: 600px; overflow: hidden; }
  .pv-madres-image img { width: 100%; height: 100%; object-fit: cover; display: block; }
  @media (max-width: 960px) {
    .pv-madres-grid { grid-template-columns: 1fr; }
    .pv-madres-text { padding: 48px 24px; }
    .pv-madres-image { min-height: 360px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Mother's Day band (Primavera)",
  "tag": "section",
  "class": "primavera-madres-section",
  "settings": [
    { "type": "paragraph", "content": "Bilingual Mother's Day / Día de las Madres band with optional live countdown. Update target date each year." },
    { "type": "header", "content": "Headlines" },
    { "type": "text", "id": "ribbon", "label": "Ribbon line (small uppercase)", "default": "Mother's Day · Día de las Madres · May 10" },
    { "type": "richtext", "id": "headline", "label": "Headline (h2)", "info": "Use <em> for italic. <br> for line break.", "default": "<h2>Para Mami,<br>con todo nuestro <em>cariño</em>.</h2>" },
    { "type": "textarea", "id": "body_es", "label": "Spanish body", "default": "Flores frescas entregadas hoy en todo Washington Heights. Toda la 10032, 10033, 10034 y 10040 antes de las cinco." },
    { "type": "textarea", "id": "body_en", "label": "English body", "default": "Hand-tied bouquets built for the day, with a Spanish or English card in your handwriting (or ours). Order before 2 PM Saturday and we'll walk it over to Mami's apartment Sunday morning." },
    { "type": "header", "content": "Countdown timer" },
    { "type": "checkbox", "id": "show_countdown", "label": "Show countdown timer", "default": true },
    { "type": "text", "id": "target_iso", "label": "Countdown target ISO date", "info": "Format: 2027-05-09T09:00:00-04:00 (Sunday of Mother's Day weekend, 9 AM Eastern).", "default": "2027-05-09T09:00:00-04:00" },
    { "type": "header", "content": "CTA" },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Shop Mother's Day →" },
    { "type": "url", "id": "cta_link", "label": "Button link" },
    { "type": "header", "content": "Image" },
    { "type": "image_picker", "id": "image", "label": "Section image", "info": "Defaults to assets/madres.png if blank." }
  ],
  "presets": [{ "name": "Mother's Day band (Primavera)", "category": "Primavera" }]
}
{% endschema %}
