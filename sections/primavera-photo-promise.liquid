{% comment %}
  Primavera, Photo-confirmation promise (2-col image + text + 3 stat row).
{% endcomment %}

<section class="pv-photo-promise pv-section">
  <div class="pv-img-side">
    {% if section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: section.settings.image.alt | default: 'Florist arranging flowers at Primavera' }}
    {% else %}
      <img src="{{ 'florist.png' | asset_url }}" alt="A florist arranging flowers at Primavera Flowers" loading="lazy">
    {% endif %}
  </div>
  <div class="pv-text-side">
    {% if section.settings.eyebrow != blank %}<span class="pv-eyebrow">{{ section.settings.eyebrow }}</span>{% endif %}
    {% if section.settings.headline != blank %}{{ section.settings.headline }}{% endif %}
    {% if section.settings.body != blank %}<p>{{ section.settings.body }}</p>{% endif %}
    <div class="pv-stat-row">
      {% for block in section.blocks %}
        <div class="pv-stat" {{ block.shopify_attributes }}>
          <div class="pv-n">{{ block.settings.value }}</div>
          <div class="pv-l">{{ block.settings.label }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .pv-section { --sage-deep:#7a8a6f; --cream:#f5efe2; --cream-2:#ece4d2; --ink:#2a2620; --ink-2:#5a544c; --ink-3:#8a847c; --line:#e2dac7; --pv-serif:"DM Serif Display","Times New Roman",serif; --pv-sans:"Inter",system-ui,-apple-system,sans-serif; }
  .pv-photo-promise { display: grid; grid-template-columns: 1fr 1fr; background: var(--cream-2); border-top: 1px solid var(--line); font-family: var(--pv-sans); color: var(--ink); }
  .pv-img-side { position: relative; min-height: 540px; overflow: hidden; }
  .pv-img-side img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .pv-text-side { padding: 72px 48px; display: flex; flex-direction: column; justify-content: center; background: var(--cream); }
  .pv-text-side .pv-eyebrow { font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--sage-deep); font-weight: 600; }
  .pv-text-side h2 { font-family: var(--pv-serif); font-weight: 400; font-size: clamp(30px,4vw,50px); line-height: 1.1; color: var(--ink); margin: 16px 0 0; }
  .pv-text-side h2 em { font-style: italic; color: var(--sage-deep); }
  .pv-text-side p { font-size: 16px; line-height: 1.7; color: var(--ink-2); max-width: 480px; margin-top: 20px; }
  .pv-stat-row { display: flex; gap: 40px; margin-top: 36px; padding-top: 24px; border-top: 1px solid var(--line); flex-wrap: wrap; }
  .pv-stat .pv-n { font-family: var(--pv-serif); font-size: 30px; color: var(--ink); line-height: 1; }
  .pv-stat .pv-l { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-3); margin-top: 6px; font-weight: 600; }
  @media (max-width: 960px) {
    .pv-photo-promise { grid-template-columns: 1fr; }
    .pv-text-side { padding: 48px 24px; }
    .pv-img-side { min-height: 320px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Primavera Photo Promise",
  "tag": "section",
  "class": "primavera-photo-promise-section",
  "max_blocks": 4,
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image (defaults to florist.png)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Primavera promise" },
    { "type": "richtext", "id": "headline", "label": "Headline (use h2)", "default": "<h2>What you see is what they <em>get</em>.</h2>" },
    { "type": "textarea", "id": "body", "label": "Body paragraph", "default": "Every order gets a quick text or email of your actual bouquet, not a stock photo, the moment it's wrapped. If something looks off, we remake it. No bait and switch. No wire-service swaps. No \"closest available.\" Just the bouquet on your screen, in your neighbor's hands." }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "value", "label": "Value (large)" },
        { "type": "text", "id": "label", "label": "Label (small uppercase)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Primavera Photo Promise",
      "blocks": [
        { "type": "stat", "settings": { "value": "Same-day", "label": "Across the Heights by 5 PM" } },
        { "type": "stat", "settings": { "value": "2 PM", "label": "Cutoff Mon to Sat" } },
        { "type": "stat", "settings": { "value": "Since 2004", "label": "Family-run on Fort Washington" } }
      ]
    }
  ]
}
{% endschema %}
