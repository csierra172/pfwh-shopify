{% comment %}
  Primavera, Featured products grid (4 cards by default).
  Cards are blocks with image, badge, name, price, description, link.
{% endcomment %}

<section class="pv-products-wrap pv-section">
  <div class="pv-sec-head">
    {% if section.settings.headline != blank %}{{ section.settings.headline }}{% endif %}
    {% if section.settings.intro != blank %}<div class="pv-right"><p>{{ section.settings.intro }}</p></div>{% endif %}
  </div>
  <div class="pv-products">
    {% for block in section.blocks %}
      <a class="pv-product" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
        <div class="pv-img-wrap">
          {% if block.settings.badge != blank %}
            <span class="pv-badge {% if block.settings.badge_style == 'rose' %}pv-rose{% endif %}">{{ block.settings.badge }}</span>
          {% endif %}
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.image.alt | default: block.settings.name }}
          {% else %}
            <img src="{{ 'hero-roses.png' | asset_url }}" alt="{{ block.settings.name | default: 'Product' }}" loading="lazy">
          {% endif %}
        </div>
        <div class="pv-row">
          <div class="pv-name">{{ block.settings.name }}</div>
          {% if block.settings.price != blank %}<div class="pv-price">{{ block.settings.price }}</div>{% endif %}
        </div>
        {% if block.settings.description != blank %}<p class="pv-desc">{{ block.settings.description }}</p>{% endif %}
      </a>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .pv-section { --sage-deep:#7a8a6f; --cream:#f5efe2; --cream-2:#ece4d2; --ink:#2a2620; --ink-2:#5a544c; --ink-3:#8a847c; --rose-deep:#b8705d; --pv-serif:"DM Serif Display","Times New Roman",serif; --pv-sans:"Inter",system-ui,-apple-system,sans-serif; }
  .pv-products-wrap { padding: 0 40px 80px; font-family: var(--pv-sans); color: var(--ink); }
  .pv-sec-head { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: end; margin: 64px 0 48px; }
  .pv-sec-head h2 { font-family: var(--pv-serif); font-weight: 400; font-size: clamp(32px,4vw,52px); line-height: 1.1; color: var(--ink); margin: 0; }
  .pv-sec-head h2 em { font-style: italic; color: var(--sage-deep); }
  .pv-sec-head .pv-right p { font-size: 16px; line-height: 1.6; color: var(--ink-2); max-width: 460px; margin: 0; }
  .pv-products { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; }
  .pv-product { display: flex; flex-direction: column; gap: 14px; text-decoration: none; color: inherit; }
  .pv-product .pv-img-wrap { aspect-ratio: 4/5; background: var(--cream-2); overflow: hidden; position: relative; border-radius: 6px; }
  .pv-product .pv-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s; display: block; }
  .pv-product:hover .pv-img-wrap img { transform: scale(1.04); }
  .pv-product .pv-badge { position: absolute; top: 12px; left: 12px; background: var(--cream); padding: 5px 10px; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink); font-weight: 600; border-radius: 4px; }
  .pv-product .pv-badge.pv-rose { background: var(--rose-deep); color: var(--cream); }
  .pv-product .pv-row { display: flex; justify-content: space-between; align-items: baseline; }
  .pv-product .pv-name { font-family: var(--pv-serif); font-size: 21px; color: var(--ink); line-height: 1.15; }
  .pv-product .pv-price { font-size: 14px; color: var(--ink-2); font-weight: 600; }
  .pv-product .pv-desc { font-size: 14px; color: var(--ink-3); line-height: 1.5; margin: 0; }
  @media (max-width: 960px) {
    .pv-products-wrap { padding: 0 24px 56px; }
    .pv-sec-head { grid-template-columns: 1fr; gap: 16px; margin: 48px 0 32px; }
    .pv-products { grid-template-columns: 1fr 1fr; gap: 18px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Primavera Products",
  "tag": "section",
  "class": "primavera-products-section",
  "max_blocks": 8,
  "settings": [
    { "type": "richtext", "id": "headline", "label": "Headline (use h2)", "default": "<h2>This week, <em>fresh in</em>.</h2>" },
    { "type": "textarea", "id": "intro", "label": "Intro paragraph", "default": "From the bench this week, ready to send today. Each one is built to order." }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Product card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Product image" },
        { "type": "text", "id": "badge", "label": "Badge label" },
        { "type": "select", "id": "badge_style", "label": "Badge style", "options": [{"value":"cream","label":"Cream"},{"value":"rose","label":"Rose"}], "default": "cream" },
        { "type": "text", "id": "name", "label": "Product name" },
        { "type": "text", "id": "price", "label": "Price line" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Primavera Products",
      "blocks": [
        { "type": "card", "settings": { "badge": "Bestseller", "badge_style": "rose", "name": "Pink Garden Roses", "price": "$69", "description": "Garden roses, ranunculus, eucalyptus. Hand-tied with raffia." } },
        { "type": "card", "settings": { "badge": "Mother's Day", "name": "Para Mami", "price": "$85", "description": "Blush roses and pink peonies, kraft-wrapped, bilingual card." } },
        { "type": "card", "settings": { "badge": "Sympathy", "name": "Sympathy Standing Spray", "price": "$175", "description": "White roses, lilies, carnations on easel. Direct to any funeral home." } },
        { "type": "card", "settings": { "badge": "New", "name": "Designer's Choice", "price": "$65 to $115", "description": "Whatever was best at market this morning, arranged for you." } }
      ]
    }
  ]
}
{% endschema %}
