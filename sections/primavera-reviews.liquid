{% comment %}
  Primavera Reviews. 3 review cards as blocks; falls back to 3 hardcoded.
{% endcomment %}

<section class="pv-reviews pv-section">
  <div class="pv-reviews-head">
    <div>
      <span class="pv-eyebrow">{{ section.settings.eyebrow | default: 'From our neighbors' }}</span>
      {% if section.settings.headline != blank %}{{ section.settings.headline }}{% else %}<h2>200+ reviews from across the <em>Heights</em>.</h2>{% endif %}
    </div>
    <div class="pv-rating">
      <div class="pv-stars">★★★★★</div>
      <div class="pv-rating-text">{{ section.settings.rating_text | default: '4.9 on Google · 200+ verified reviews' }}</div>
    </div>
  </div>
  <div class="pv-reviews-grid">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        <div class="pv-review" {{ block.shopify_attributes }}>
          <div class="pv-review-stars">★★★★★</div>
          <p class="pv-review-text">{{ block.settings.quote | default: '"Best florist in the Heights."' }}</p>
          <div class="pv-review-author">
            <div class="pv-review-avatar">{{ block.settings.name | default: 'X' | slice: 0, 1 }}</div>
            <div>
              <div class="pv-review-name">{{ block.settings.name | default: 'Neighbor' }}</div>
              <div class="pv-review-date">{{ block.settings.source | default: 'Google review' }}</div>
            </div>
          </div>
        </div>
      {% endfor %}
    {% else %}
      <div class="pv-review"><div class="pv-review-stars">★★★★★</div><p class="pv-review-text">"My friends make the most beautiful floral arrangements in Washington Heights. They have been my go-to for every holiday."</p><div class="pv-review-author"><div class="pv-review-avatar">D</div><div><div class="pv-review-name">Diana L.</div><div class="pv-review-date">Verified neighbor · @dianalopnyc</div></div></div></div>
      <div class="pv-review"><div class="pv-review-stars">★★★★★</div><p class="pv-review-text">"Ordered last minute for my mom's birthday. Got a photo of the arrangement before delivery. Gorgeous, and at her door an hour later. Real local florist."</p><div class="pv-review-author"><div class="pv-review-avatar">M</div><div><div class="pv-review-name">Marcus G.</div><div class="pv-review-date">Google review · 3 weeks ago</div></div></div></div>
      <div class="pv-review"><div class="pv-review-stars">★★★★★</div><p class="pv-review-text">"Best florist in the Heights. They speak Spanish, they know my mom's name, and they stayed late so I could pick up flowers for a vigil. Family."</p><div class="pv-review-author"><div class="pv-review-avatar">R</div><div><div class="pv-review-name">Rosa M.</div><div class="pv-review-date">Google review · 1 month ago</div></div></div></div>
    {% endif %}
  </div>
  {% if section.settings.cta_label != blank or section.settings.show_cta_default != false %}
    <div class="pv-reviews-cta">
      <a href="{{ section.settings.cta_link | default: 'https://www.google.com/search?q=Primavera+Flowers+NYC+Reviews' }}" target="_blank" rel="noopener">{{ section.settings.cta_label | default: 'Read all reviews on Google →' }}</a>
    </div>
  {% endif %}
</section>

{% stylesheet %}
  .pv-section { --sage:#a8b59a; --sage-deep:#7a8a6f; --cream:#f5efe2; --paper:#faf6ec; --ink:#2a2620; --ink-2:#5a544c; --ink-3:#8a847c; --rose-deep:#b8705d; --line:#e2dac7; --pv-serif:"DM Serif Display","Times New Roman",serif; --pv-sans:"Inter",system-ui,-apple-system,sans-serif; }
  .pv-reviews { background: var(--cream); border-top: 1px solid var(--line); padding: 80px 40px; font-family: var(--pv-sans); color: var(--ink); }
  .pv-reviews-head { display: flex; justify-content: space-between; align-items: end; margin-bottom: 40px; gap: 32px; flex-wrap: wrap; }
  .pv-eyebrow { font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--sage-deep); font-weight: 600; display: block; margin-bottom: 12px; }
  .pv-reviews-head h2 { font-family: var(--pv-serif); font-weight: 400; font-size: clamp(30px,4vw,50px); line-height: 1.1; color: var(--ink); margin: 0; }
  .pv-reviews-head h2 em { font-style: italic; color: var(--sage-deep); }
  .pv-rating { display: flex; align-items: center; gap: 12px; }
  .pv-stars { font-size: 18px; color: #f5b454; letter-spacing: 1px; }
  .pv-rating-text { font-size: 14px; color: var(--ink-2); font-weight: 600; }
  .pv-reviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .pv-review { background: var(--paper); padding: 28px 26px; border-radius: 8px; border: 1px solid var(--line); display: flex; flex-direction: column; gap: 14px; }
  .pv-review-stars { font-size: 14px; color: #f5b454; letter-spacing: 1px; }
  .pv-review-text { font-size: 15px; color: var(--ink); line-height: 1.55; margin: 0; }
  .pv-review-author { display: flex; align-items: center; gap: 10px; margin-top: auto; padding-top: 12px; border-top: 1px solid var(--line); }
  .pv-review-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--sage); color: var(--cream); display: grid; place-content: center; font-weight: 600; font-size: 13px; }
  .pv-review-name { font-size: 13px; color: var(--ink-2); font-weight: 600; }
  .pv-review-date { font-size: 12px; color: var(--ink-3); }
  .pv-reviews-cta { text-align: center; margin-top: 40px; }
  .pv-reviews-cta a { color: var(--sage-deep); font-weight: 600; font-size: 14px; border-bottom: 1.5px solid var(--sage-deep); padding-bottom: 2px; text-decoration: none; }
  .pv-reviews-cta a:hover { color: var(--rose-deep); border-color: var(--rose-deep); }
  @media (max-width: 960px) {
    .pv-reviews { padding: 56px 24px; }
    .pv-reviews-grid { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Reviews (Primavera)",
  "tag": "section",
  "class": "primavera-reviews-section",
  "max_blocks": 9,
  "settings": [
    { "type": "paragraph", "content": "Customer reviews block. Each review is a block — add up to 9. Falls back to 3 hardcoded reviews if you remove all blocks." },
    { "type": "header", "content": "Section heading" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "From our neighbors" },
    { "type": "richtext", "id": "headline", "label": "Headline (h2)", "default": "<h2>200+ reviews from across the <em>Heights</em>.</h2>" },
    { "type": "text", "id": "rating_text", "label": "Rating text (next to stars)", "info": "Shows on the right side of the heading next to ★★★★★", "default": "4.9 on Google · 200+ verified reviews" },
    { "type": "header", "content": "Footer link" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Read all reviews on Google →" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote", "info": "Wrap in straight quotes for stylistic consistency.", "default": "\"Best florist in the Heights.\"" },
        { "type": "text", "id": "name", "label": "Reviewer name", "default": "Neighbor X" },
        { "type": "text", "id": "source", "label": "Source line", "info": "e.g. 'Google review · 3 weeks ago'", "default": "Google review" }
      ]
    }
  ],
  "presets": [{ "name": "Reviews (Primavera)", "category": "Primavera" }]
}
{% endschema %}
