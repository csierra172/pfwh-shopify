{% comment %}
  Primavera Flowers — dedicated Subscriptions page section.
  Three tiers: Casa, Familia, Estudio. Same brand palette as primavera-landing.
  Page handle: subscriptions  /  Template: page.subscriptions.json
{% endcomment %}

<style>
  .ps {
    --sage:        #a8b59a;
    --sage-deep:   #7a8a6f;
    --sage-soft:   #c8d2bc;
    --cream:       #f5efe2;
    --cream-2:     #ece4d2;
    --paper:       #faf6ec;
    --ink:         #2a2620;
    --ink-2:       #5a544c;
    --ink-3:       #8a847c;
    --rose:        #d39283;
    --rose-deep:   #b8705d;
    --line:        #e2dac7;
    --ps-serif:    "DM Serif Display", "Times New Roman", serif;
    --ps-sans:     "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--cream); color: var(--ink); font-family: var(--ps-sans);
    font-size: 17px; line-height: 1.55; -webkit-font-smoothing: antialiased;
  }
  .ps * { box-sizing: border-box; margin: 0; padding: 0; }
  .ps a { color: inherit; text-decoration: none; }

  /* Hero */
  .ps-hero { padding: 88px 40px 56px; text-align: center; max-width: 880px; margin: 0 auto; }
  .ps-hero .ps-eyebrow { font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--sage-deep); font-weight: 600; margin-bottom: 18px; }
  .ps-hero h1 { font-family: var(--ps-serif); font-weight: 400; font-size: clamp(40px, 5vw, 64px); line-height: 1.05; color: var(--ink); margin-bottom: 22px; }
  .ps-hero h1 em { font-style: italic; color: var(--sage-deep); }
  .ps-hero .ps-lede { font-size: 18px; line-height: 1.6; color: var(--ink-2); max-width: 620px; margin: 0 auto; }

  /* Tiers */
  .ps-tiers { padding: 16px 40px 80px; }
  .ps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; max-width: 1200px; margin: 0 auto; }
  .ps-card { background: var(--paper); padding: 40px 30px; border-radius: 8px; border: 1px solid var(--line); display: flex; flex-direction: column; min-height: 420px; }
  .ps-card.ps-featured { background: var(--sage-deep); color: var(--cream); border-color: var(--sage-deep); }
  .ps-card.ps-featured .ps-name, .ps-card.ps-featured .ps-price { color: var(--cream); }
  .ps-card.ps-featured .ps-meta, .ps-card.ps-featured .ps-feat li { color: rgba(245, 239, 226, 0.85); }
  .ps-tag { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--rose-deep); font-weight: 600; margin-bottom: 22px; }
  .ps-card.ps-featured .ps-tag { color: var(--rose); }
  .ps-name { font-family: var(--ps-serif); font-size: 36px; color: var(--ink); line-height: 1; }
  .ps-price { font-family: var(--ps-serif); font-size: 26px; color: var(--ink); margin-top: 14px; }
  .ps-price small { font-family: var(--ps-sans); font-size: 13px; color: var(--ink-3); margin-left: 6px; font-weight: 400; }
  .ps-card.ps-featured .ps-price small { color: rgba(245, 239, 226, 0.7); }
  .ps-meta { font-size: 13px; color: var(--ink-3); margin-top: 8px; }
  .ps-feat { list-style: none; margin: 28px 0; padding: 0; display: flex; flex-direction: column; gap: 10px; }
  .ps-feat li { font-size: 14px; color: var(--ink-2); padding-left: 22px; position: relative; line-height: 1.5; }
  .ps-feat li::before { content: "✓"; position: absolute; left: 0; top: 0; color: var(--sage-deep); font-weight: 600; }
  .ps-card.ps-featured .ps-feat li::before { color: var(--rose); }
  .ps-btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 26px; border-radius: 6px; font-size: 15px; font-weight: 600; transition: all .15s; border: none; cursor: pointer; background: var(--sage-deep); color: var(--cream); margin-top: auto; align-self: flex-start; }
  .ps-btn:hover { background: var(--ink); }
  .ps-card.ps-featured .ps-btn { background: var(--cream); color: var(--ink); }
  .ps-card.ps-featured .ps-btn:hover { background: var(--rose); color: var(--cream); }

  /* How it works */
  .ps-how { background: var(--paper); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); padding: 80px 40px; }
  .ps-how-inner { max-width: 1100px; margin: 0 auto; }
  .ps-how h2 { font-family: var(--ps-serif); font-weight: 400; font-size: clamp(32px, 4vw, 48px); line-height: 1.1; color: var(--ink); text-align: center; margin-bottom: 14px; }
  .ps-how h2 em { font-style: italic; color: var(--sage-deep); }
  .ps-how .ps-sub { text-align: center; color: var(--ink-2); max-width: 580px; margin: 0 auto 48px; }
  .ps-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; }
  .ps-step .ps-num { font-size: 12px; letter-spacing: 0.14em; color: var(--sage-deep); font-weight: 600; }
  .ps-step .ps-t { font-family: var(--ps-serif); font-size: 22px; line-height: 1.2; margin: 10px 0 8px; color: var(--ink); }
  .ps-step .ps-d { font-size: 14px; line-height: 1.55; color: var(--ink-2); }

  /* FAQ */
  .ps-faq { padding: 80px 40px; max-width: 800px; margin: 0 auto; }
  .ps-faq h2 { font-family: var(--ps-serif); font-weight: 400; font-size: clamp(30px, 3.5vw, 42px); line-height: 1.1; color: var(--ink); text-align: center; margin-bottom: 40px; }
  .ps-faq h2 em { font-style: italic; color: var(--sage-deep); }
  .ps-faq details { border-top: 1px solid var(--line); padding: 22px 0; }
  .ps-faq details:last-of-type { border-bottom: 1px solid var(--line); }
  .ps-faq summary { font-family: var(--ps-serif); font-size: 20px; color: var(--ink); cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .ps-faq summary::-webkit-details-marker { display: none; }
  .ps-faq summary::after { content: "+"; font-family: var(--ps-sans); font-weight: 300; font-size: 26px; color: var(--sage-deep); }
  .ps-faq details[open] summary::after { content: "−"; }
  .ps-faq details p { font-size: 15px; color: var(--ink-2); margin-top: 14px; line-height: 1.6; }

  @media (max-width: 960px) {
    .ps-hero { padding: 56px 24px 40px; }
    .ps-tiers { padding: 8px 24px 56px; }
    .ps-grid { grid-template-columns: 1fr; }
    .ps-how, .ps-faq { padding: 56px 24px; }
    .ps-steps { grid-template-columns: 1fr 1fr; gap: 22px; }
  }
</style>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<div class="ps">

  <section class="ps-hero">
    <span class="ps-eyebrow">★ 4.9 on Google · Hablamos español · Free vase with first delivery</span>
    <h1>Flowers as part of <em>everyday life</em>.</h1>
    <p class="ps-lede">A standing order from your real, local florist on Fort Washington Avenue — not a 1-800 wire service. Pick a tier, pick a frequency, and we hand-deliver across Washington Heights, Hudson Heights, and Inwood. Pause, skip, or cancel from your phone. No contracts, no fees, no surprises.</p>
  </section>

  <section class="ps-tiers">
    <div class="ps-grid">

      <div class="ps-card">
        <span class="ps-tag">Casa · The starter</span>
        <div class="ps-name">Casa</div>
        <div class="ps-price">$60<small>/ delivery</small></div>
        <div class="ps-meta">Bi-weekly · designer's choice</div>
        <ul class="ps-feat">
          <li>Five-stem hand-tied bouquet, built for the kitchen counter</li>
          <li>Always seasonal — whatever's best at the 28th Street market that morning</li>
          <li>Skip or pause any week from your phone</li>
          <li>Free hand-delivery in Washington Heights, Hudson Heights, and Inwood</li>
          <li>Photo of your actual bouquet before it leaves the shop</li>
        </ul>
        <a class="ps-btn" href="/products/subscription-classic">Start Casa →</a>
      </div>

      <div class="ps-card ps-featured">
        <span class="ps-tag">Familia · Most loved</span>
        <div class="ps-name">Familia</div>
        <div class="ps-price">$75<small>/ delivery</small></div>
        <div class="ps-meta">Weekly · larger, with a card</div>
        <ul class="ps-feat">
          <li>Eight-stem garden bouquet — the kitchen-island size</li>
          <li><strong>Free glass vase</strong> with your first delivery</li>
          <li>Bilingual handwritten card (English or Spanish)</li>
          <li>Skip, pause, or gift any week — perfect for sending Mami flowers all year</li>
          <li>Free hand-delivery across upper Manhattan</li>
        </ul>
        <a class="ps-btn" href="/products/subscription-seasonal">Start Familia →</a>
      </div>

      <div class="ps-card">
        <span class="ps-tag">Estudio · For business</span>
        <div class="ps-name">Estudio</div>
        <div class="ps-price">$105<small>/ delivery</small></div>
        <div class="ps-meta">Weekly · for offices, lobbies, salons</div>
        <ul class="ps-feat">
          <li>Twelve-stem statement piece — built for the front desk</li>
          <li>Vase rotation and weekly refresh on every drop</li>
          <li>Net-30 invoicing for businesses</li>
          <li>Holiday installations and seasonal swaps included</li>
          <li>Dedicated account designer at the Fort Washington shop</li>
        </ul>
        <a class="ps-btn" href="/products/subscription-luxe">Start Estudio →</a>
      </div>

    </div>
  </section>

  <section class="ps-how">
    <div class="ps-how-inner">
      <h2>How it <em>works</em>.</h2>
      <p class="ps-sub">A standing order from a real florist on Fort Washington — not a 1-800 number routing your stems through three states.</p>
      <div class="ps-steps">
        <div class="ps-step">
          <div class="ps-num">01</div>
          <div class="ps-t">Pick your tier</div>
          <div class="ps-d">Casa for a small Tuesday gesture, Familia for the kitchen island, Estudio for the lobby.</div>
        </div>
        <div class="ps-step">
          <div class="ps-num">02</div>
          <div class="ps-t">We design it Friday morning</div>
          <div class="ps-d">Our buyer is at the 28th Street market by 5 AM. The bouquet is built that morning at the shop on Fort Washington.</div>
        </div>
        <div class="ps-step">
          <div class="ps-num">03</div>
          <div class="ps-t">Photo before it leaves</div>
          <div class="ps-d">You get a quick text or email of the actual bouquet before our driver heads out — no surprises.</div>
        </div>
        <div class="ps-step">
          <div class="ps-num">04</div>
          <div class="ps-t">Hand-delivered, same day</div>
          <div class="ps-d">Walked or driven across Washington Heights, Inwood, the Cloisters, and Marble Hill. Pause or skip from your account.</div>
        </div>
      </div>
    </div>
  </section>

  <section class="ps-faq">
    <h2>Subscription <em>questions</em>.</h2>
    <details>
      <summary>Where do you deliver subscriptions?</summary>
      <p>Free delivery to ZIPs 10032, 10033, 10034, 10040, 10031, and 10039 — that's all of Washington Heights, Hudson Heights, Inwood, and Hamilton Heights. Marble Hill (10463) and the Cloisters area are included. Outside that zone, we add a small fee at checkout.</p>
    </details>
    <details>
      <summary>Can I pause or skip a week?</summary>
      <p>Yes — log into your account or text the shop at (917) 770-1684. We can pause, skip a single week, or change the delivery day. No fees, no contracts.</p>
    </details>
    <details>
      <summary>What if I'm not home?</summary>
      <p>We leave bouquets in a vestibule or with a doorman if you have one. Most of the buildings on Fort Washington and Pinehurst know us by sight. If you'd rather pick up at the shop, we'll hold it cooled until 6 PM.</p>
    </details>
    <details>
      <summary>Can I gift a subscription?</summary>
      <p>Absolutely — Familia is the most-gifted tier. Choose "gift" at checkout, add the recipient's address, and pick how many weeks. We'll include a handwritten note in your name and email you when each delivery lands.</p>
    </details>
    <details>
      <summary>¿Hablan español?</summary>
      <p>Sí. Toda la familia. Si prefieres ordenar o coordinar entregas en español, llámanos al (917) 770-1684 o pásate por la tienda en 463 Fort Washington Ave.</p>
    </details>
  </section>

</div>

{% schema %}
{
  "name": "Primavera Subscriptions",
  "tag": "section",
  "class": "primavera-subscriptions-section",
  "settings": [
    { "type": "header", "content": "About this section" },
    { "type": "paragraph", "content": "Dedicated subscriptions page content. Three tiers (Casa / Familia / Estudio), how-it-works steps, and a Washington-Heights-specific FAQ. Lives at /pages/subscriptions." }
  ],
  "presets": [ { "name": "Primavera Subscriptions" } ]
}
{% endschema %}
