{% doc %}
  Product page trust signals — render inside product-information section.
  Photo-confirmation · Same-day · Hand-delivered · Free over $125.
  Position via CSS where injected.
{% enddoc %}

<ul class="product-trust-badges" role="list" aria-label="Trust signals">
  <li class="product-trust-badges__item">
    <span class="product-trust-badges__icon" aria-hidden="true">📸</span>
    <span class="product-trust-badges__label">
      <strong>Photo-confirmed</strong><br>
      <small>before it leaves the shop</small>
    </span>
  </li>
  <li class="product-trust-badges__item">
    <span class="product-trust-badges__icon" aria-hidden="true">⏱</span>
    <span class="product-trust-badges__label">
      <strong>Same-day before 2pm</strong><br>
      <small>10032 · 10033 · 10034 · 10040</small>
    </span>
  </li>
  <li class="product-trust-badges__item">
    <span class="product-trust-badges__icon" aria-hidden="true">🚲</span>
    <span class="product-trust-badges__label">
      <strong>Hand-delivered</strong><br>
      <small>by a designer or local driver</small>
    </span>
  </li>
  <li class="product-trust-badges__item">
    <span class="product-trust-badges__icon" aria-hidden="true">🎁</span>
    <span class="product-trust-badges__label">
      <strong>Free delivery over $125</strong><br>
      <small>$15 flat under that</small>
    </span>
  </li>
</ul>

<style>
  .product-trust-badges {
    list-style: none;
    padding: 16px;
    margin: 16px 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px 16px;
    border: 1px solid var(--color-border, rgba(0,0,0,0.1));
    background: rgba(232, 199, 192, 0.18);
    border-radius: 2px;
  }
  .product-trust-badges__item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.85rem;
    line-height: 1.3;
  }
  .product-trust-badges__icon {
    font-size: 1.1rem;
    flex-shrink: 0;
  }
  .product-trust-badges__label small {
    opacity: 0.7;
    font-size: 0.78rem;
  }
  @media (max-width: 600px) {
    .product-trust-badges { grid-template-columns: 1fr; gap: 10px; }
  }
</style>
