/*
 * ------------------------------------------------------------
 * Primavera Flowers — Homepage
 * Hero -> same-day promise marquee -> shop by occasion ->
 * bestsellers -> photo-confirmation USP -> story -> care guides
 * ------------------------------------------------------------
 */{
  "sections": {
    "hero": {
      "type": "hero",
      "blocks": {
        "group_hero": {
          "type": "group",
          "blocks": {
            "kicker": {
              "type": "text",
              "settings": {
                "text": "<p>The Washington Heights florist.</p>",
                "alignment": "left",
                "type_preset": "paragraph",
                "font": "var(--font-accent--family)",
                "case": "uppercase",
                "letter_spacing": "0.12em",
                "color": ""
              }
            },
            "headline": {
              "type": "text",
              "settings": {
                "text": "<h1>Hand-delivered flowers, designed by neighbors.</h1>",
                "alignment": "left",
                "type_preset": "h1",
                "font": "var(--font-heading--family)",
                "case": "none",
                "wrap": "balance",
                "color": ""
              }
            },
            "subhead": {
              "type": "text",
              "settings": {
                "text": "<p>Order by 2pm and we deliver the same day across 10032, 10033, 10034, 10040 and the South Bronx. We send you a photo of your bouquet before it leaves the shop.</p>",
                "alignment": "left",
                "type_preset": "paragraph",
                "max_width": "narrow"
              }
            },
            "cta_primary": {
              "type": "button",
              "settings": {
                "label": "Shop bestsellers",
                "link": "shopify://collections/bestsellers",
                "style_class": "primary"
              }
            },
            "cta_secondary": {
              "type": "button",
              "settings": {
                "label": "Same-day delivery →",
                "link": "shopify://collections/same-day",
                "style_class": "link"
              }
            }
          },
          "block_order": ["kicker", "headline", "subhead", "cta_primary", "cta_secondary"],
          "settings": {
            "content_direction": "column",
            "horizontal_alignment": "flex-start",
            "vertical_alignment": "center",
            "gap": 16,
            "width": "custom",
            "custom_width": 50,
            "custom_width_mobile": 90,
            "padding-block-start": 80,
            "padding-block-end": 80,
            "padding-inline-start": 48,
            "padding-inline-end": 48
          }
        }
      },
      "block_order": ["group_hero"],
      "settings": {
        "section_width": "page-width",
        "section_height": "large",
        "color_scheme": "scheme-1",
        "horizontal_alignment": "flex-start",
        "vertical_alignment": "center",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
    "promise_marquee": {
      "type": "marquee",
      "blocks": {
        "p1": { "type": "_announcement", "settings": { "text": "Same-day delivery before 2pm" } },
        "p2": { "type": "_announcement", "settings": { "text": "Photo-confirmed before it leaves the shop" } },
        "p3": { "type": "_announcement", "settings": { "text": "Locally designed in Washington Heights since 1995" } },
        "p4": { "type": "_announcement", "settings": { "text": "Flores frescas entregadas hoy en 10032" } },
        "p5": { "type": "_announcement", "settings": { "text": "Sympathy arrangements with care" } }
      },
      "block_order": ["p1", "p2", "p3", "p4", "p5"],
      "settings": {
        "color_scheme": "scheme-2",
        "speed": 30,
        "section_width": "full-width",
        "padding-block-start": 16,
        "padding-block-end": 16
      }
    },
    "shop_by_occasion": {
      "type": "collection-links",
      "blocks": {
        "h": {
          "type": "_inline-collection-title",
          "settings": {
            "text": "<h2>Shop by occasion</h2>",
            "alignment": "center",
            "type_preset": "h2",
            "font": "var(--font-heading--family)"
          }
        },
        "birthday": { "type": "_collection-link", "settings": { "collection": "birthday", "label": "Birthday" } },
        "anniversary": { "type": "_collection-link", "settings": { "collection": "anniversary", "label": "Anniversary" } },
        "sympathy": { "type": "_collection-link", "settings": { "collection": "sympathy", "label": "Sympathy" } },
        "just-because": { "type": "_collection-link", "settings": { "collection": "just-because", "label": "Just Because" } },
        "get-well": { "type": "_collection-link", "settings": { "collection": "get-well", "label": "Get Well" } },
        "new-baby": { "type": "_collection-link", "settings": { "collection": "new-baby", "label": "New Baby" } },
        "quinceanera": { "type": "_collection-link", "settings": { "collection": "quinceanera", "label": "Quinceañera" } },
        "madres": { "type": "_collection-link", "settings": { "collection": "dia-de-las-madres", "label": "Día de las Madres" } }
      },
      "block_order": ["h", "birthday", "anniversary", "sympathy", "just-because", "get-well", "new-baby", "quinceanera", "madres"],
      "settings": {
        "color_scheme": "scheme-1",
        "section_width": "page-width",
        "padding-block-start": 64,
        "padding-block-end": 32
      }
    },
    "bestsellers": {
      "type": "product-list",
      "blocks": {
        "static-header": {
          "type": "_product-list-content",
          "static": true,
          "blocks": {
            "title": {
              "type": "text",
              "settings": {
                "text": "<h2>Bestsellers this week</h2>",
                "alignment": "center",
                "type_preset": "h2",
                "font": "var(--font-heading--family)"
              }
            }
          },
          "block_order": ["title"]
        },
        "static-product-card": {
          "type": "_product-card",
          "static": true,
          "blocks": {
            "gallery": {
              "type": "_product-card-gallery",
              "settings": { "image_ratio": "portrait" }
            },
            "info": {
              "type": "_product-card-group",
              "blocks": {
                "title": {
                  "type": "product-title",
                  "settings": {
                    "alignment": "left",
                    "type_preset": "h5",
                    "font": "var(--font-heading--family)",
                    "font_size": "1.25rem",
                    "case": "none"
                  }
                },
                "price": {
                  "type": "price",
                  "settings": {
                    "alignment": "left",
                    "type_preset": "paragraph",
                    "font": "var(--font-body--family)"
                  }
                }
              },
              "block_order": ["title", "price"]
            }
          },
          "block_order": ["gallery", "info"]
        }
      },
      "name": "Bestsellers",
      "settings": {
        "collection": "bestsellers",
        "layout_type": "grid",
        "max_products": 8,
        "columns": 4,
        "mobile_columns": "2",
        "section_width": "page-width",
        "color_scheme": "scheme-1",
        "padding-block-start": 32,
        "padding-block-end": 64
      }
    },
    "photo_confirmation": {
      "type": "media-with-content",
      "blocks": {
        "kicker": {
          "type": "text",
          "settings": {
            "text": "<p>What you see is what arrives.</p>",
            "alignment": "left",
            "type_preset": "paragraph",
            "font": "var(--font-accent--family)",
            "case": "uppercase",
            "letter_spacing": "0.14em"
          }
        },
        "headline": {
          "type": "text",
          "settings": {
            "text": "<h2>We photograph every bouquet before it leaves the shop.</h2>",
            "alignment": "left",
            "type_preset": "h2",
            "font": "var(--font-heading--family)",
            "case": "none"
          }
        },
        "body": {
          "type": "text",
          "settings": {
            "text": "<p>No surprises, no stand-ins, no \"designer's choice\" left to chance. The arrangement you see in the photo is the one being driven to your door — and we email it to you the moment it goes out.</p>",
            "alignment": "left",
            "type_preset": "paragraph",
            "max_width": "narrow"
          }
        }
      },
      "block_order": ["kicker", "headline", "body"],
      "settings": {
        "color_scheme": "scheme-3",
        "section_width": "full-width",
        "media_position": "left",
        "media_width": 50,
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
    "neighborhood_story": {
      "type": "media-with-content",
      "blocks": {
        "kicker": {
          "type": "text",
          "settings": {
            "text": "<p>463 Fort Washington Ave · 10033</p>",
            "alignment": "left",
            "type_preset": "paragraph",
            "font": "var(--font-accent--family)",
            "case": "uppercase",
            "letter_spacing": "0.14em"
          }
        },
        "headline": {
          "type": "text",
          "settings": {
            "text": "<h2>Three blocks from the A train. A florist for the Heights since 1995.</h2>",
            "alignment": "left",
            "type_preset": "h2",
            "font": "var(--font-heading--family)",
            "case": "none"
          }
        },
        "body": {
          "type": "text",
          "settings": {
            "text": "<p>Primavera is a family-run shop, designing arrangements for births, weddings, sympathy, and every Sunday brunch in between. We're proud to be your neighborhood florist — and grateful for two decades of trust from Washington Heights, Inwood, and the Bronx.</p>",
            "alignment": "left",
            "type_preset": "paragraph",
            "max_width": "narrow"
          }
        },
        "cta": {
          "type": "button",
          "settings": {
            "label": "Our story",
            "link": "shopify://pages/our-story",
            "style_class": "secondary"
          }
        }
      },
      "block_order": ["kicker", "headline", "body", "cta"],
      "settings": {
        "color_scheme": "scheme-1",
        "section_width": "full-width",
        "media_position": "right",
        "media_width": 50,
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
    "trust_badges": {
      "type": "marquee",
      "blocks": {
        "t1": { "type": "_announcement", "settings": { "text": "★★★★★ Hand-delivered in Washington Heights" } },
        "t2": { "type": "_announcement", "settings": { "text": "★★★★★ Photo-confirmed before it leaves the shop" } },
        "t3": { "type": "_announcement", "settings": { "text": "★★★★★ Same-day before 2pm · Free over $125" } },
        "t4": { "type": "_announcement", "settings": { "text": "★★★★★ Locally designed since 1995" } },
        "t5": { "type": "_announcement", "settings": { "text": "★★★★★ Sympathy concierge with funeral home partners" } }
      },
      "block_order": ["t1", "t2", "t3", "t4", "t5"],
      "settings": {
        "color_scheme": "scheme-3",
        "speed": 25,
        "section_width": "full-width",
        "padding-block-start": 14,
        "padding-block-end": 14
      }
    },
    "testimonials": {
      "type": "media-with-content",
      "blocks": {
        "kicker": {
          "type": "text",
          "settings": {
            "text": "<p>What neighbors say</p>",
            "alignment": "left",
            "type_preset": "paragraph",
            "font": "var(--font-accent--family)",
            "case": "uppercase",
            "letter_spacing": "0.16em"
          }
        },
        "quote1": {
          "type": "text",
          "settings": {
            "text": "<blockquote><p>\"Beautiful arrangement, exactly like the photo. The driver showed up within the window, even called ahead. Will absolutely use again for sympathy needs.\"</p><p style=\"font-size:0.85em;opacity:0.7;margin-top:8px\">— Maria R., 10033 · Google Review</p></blockquote>",
            "alignment": "left",
            "type_preset": "paragraph",
            "max_width": "narrow"
          }
        },
        "quote2": {
          "type": "text",
          "settings": {
            "text": "<blockquote><p>\"Last-minute Mother's Day order at noon, delivered to my mom in Inwood by 4pm. The bouquet was bigger than I expected. Photo email was a nice touch.\"</p><p style=\"font-size:0.85em;opacity:0.7;margin-top:8px\">— David S., Mother's Day 2025 · Google Review</p></blockquote>",
            "alignment": "left",
            "type_preset": "paragraph",
            "max_width": "narrow"
          }
        },
        "quote3": {
          "type": "text",
          "settings": {
            "text": "<blockquote><p>\"They handled a difficult sympathy delivery to a funeral home with so much care. Coordinated with the staff directly. Lifted a huge weight off our family.\"</p><p style=\"font-size:0.85em;opacity:0.7;margin-top:8px\">— Anonymous · Google Review</p></blockquote>",
            "alignment": "left",
            "type_preset": "paragraph",
            "max_width": "narrow"
          }
        }
      },
      "block_order": ["kicker", "quote1", "quote2", "quote3"],
      "settings": {
        "color_scheme": "scheme-1",
        "section_width": "page-width",
        "media_position": "right",
        "media_width": 40,
        "padding-block-start": 64,
        "padding-block-end": 64
      }
    },
    "care_guides": {
      "type": "featured-blog-posts",
      "blocks": {
        "title": {
          "type": "text",
          "settings": {
            "text": "<h2>From the workroom</h2>",
            "alignment": "center",
            "type_preset": "h2",
            "font": "var(--font-heading--family)",
            "case": "none"
          }
        }
      },
      "block_order": ["title"],
      "settings": {
        "blog": "care-and-stories",
        "max_posts": 3,
        "columns": 3,
        "section_width": "page-width",
        "color_scheme": "scheme-1",
        "padding-block-start": 64,
        "padding-block-end": 64
      }
    }
  },
  "order": [
    "hero",
    "trust_badges",
    "promise_marquee",
    "shop_by_occasion",
    "bestsellers",
    "photo_confirmation",
    "testimonials",
    "neighborhood_story",
    "care_guides"
  ]
}
