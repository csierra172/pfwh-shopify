      "type": "media-with-content",
      "blocks": {
        "h": { "type": "text", "settings": { "text": "<h2>Every 2 days</h2>", "type_preset": "h2", "font": "var(--font-heading--family)", "case": "none" } },
        "body": { "type": "text", "settings": { "text": "<ul><li>Re-cut stems, dump and refill the water.</li><li>Pull any browning blooms. They release ethylene gas that kills the rest.</li></ul>", "type_preset": "paragraph" } }
      },
      "block_order": ["h", "body"],
