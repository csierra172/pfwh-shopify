        "body": { "type": "text", "settings": { "text": "<ul><li>Out of direct sunlight</li><li>Away from radiators, AC vents, and ripe fruit</li><li>Cool overnight if possible (some pros put bouquets in the fridge, yes really)</li></ul>", "type_preset": "paragraph" } }
