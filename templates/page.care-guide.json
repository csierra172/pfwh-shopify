      "blocks": {
        "h": { "type": "text", "settings": { "text": "<h2>Day 1. First 10 minutes home.</h2>", "type_preset": "h2", "font": "var(--font-heading--family)", "case": "none" } },
        "body": { "type": "text", "settings": { "text": "<ol><li>Untie the bouquet right when you get it home.</li><li>Trim each stem at a 45° angle, about 1 inch off, with a sharp knife or pruning shears (kitchen scissors crush the stem).</li><li>Strip any leaves below the waterline. Leaves underwater rot.</li><li>Fill a clean vase 2/3 full with cold water plus the flower food packet we included.</li></ol>", "type_preset": "paragraph" } }
      },
      "block_order": ["h", "body"],
      "settings": { "color_scheme": "scheme-1", "section_width": "page-width", "media_position": "right", "media_width": 40, "padding-block-start": 40, "padding-block-end": 40 }
